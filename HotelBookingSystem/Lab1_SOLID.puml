
@startuml Lab1_SOLID_Principles

skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam classFontName "Segoe UI"
skinparam defaultFontName "Segoe UI"
skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam nodesep 50
skinparam ranksep 50

skinparam class {
    BackgroundColor #FEFEFE
    BorderColor #546E7A
    ArrowColor #546E7A
    HeaderBackgroundColor #E3F2FD
}

skinparam interface {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
}

skinparam abstract {
    BackgroundColor #FFF3E0
    BorderColor #E65100
}

skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title <b>Laboratory 1 — OOP Recap and SOLID Principles\nHotel Booking System</b>

' ============================================
' CONTROLLERS (SRP - each has ONE responsibility)
' ============================================
package "Controllers (SRP)" as controllers #F3E5F5 {

    abstract class BaseViewModel {
        + <<event>> PropertyChanged : PropertyChangedEventHandler
        --
        # OnPropertyChanged(propertyName) : void
        # SetProperty<T>(ref field, value, propertyName) : bool
    }

    class GuestController {
        - _userRepository : IUserRepository
        - _userValidator : IUserValidator
        - _currentUser : User
        --
        + GuestName : string
        + GuestEmail : string
        + GuestNationality : string
        + GuestPassport : string
        + CurrentUser : User
        + <<event>> OnLog : Action<string>
        --
        + CreateGuest() : void
    }

    class RoomController {
        - _roomRepository : IRoomRepository
        - _roomPricingService : IRoomPricingService
        - _currentRoom : Room
        --
        + RoomNumber : string
        + RoomPrice : decimal
        + RoomCapacity : int
        + SelectedRoomType : string
        + RoomTypes : List<string>
        + CurrentRoom : Room
        + <<event>> OnLog : Action<string>
        --
        + CreateRoom() : void
    }

    class BookingController {
        - _bookingService : IBookingService
        - _bookingRepository : IBookingRepository
        - _durationCalculator : IBookingDurationCalculator
        --
        + Bookings : ObservableCollection<Booking>
        + SelectedBooking : Booking
        + <<event>> OnLog : Action<string>
        --
        + CreateBooking(user, room, pricingService) : void
        + ConfirmBooking() : void
        + CancelBooking() : void
        + RefreshBookings() : void
    }

    class LogController {
        - _logger : ILogger
        --
        + LogOutput : string
        --
        + AddLog(message) : void
    }

    class MainViewModel {
        - _roomPricingService : IRoomPricingService
        --
        + GuestCtrl : GuestController
        + RoomCtrl : RoomController
        + BookingCtrl : BookingController
        + LogCtrl : LogController
        + CreateGuestCommand : ICommand
        + CreateRoomCommand : ICommand
        + CreateBookingCommand : ICommand
        + RefreshBookingsCommand : ICommand
        + ConfirmBookingCommand : ICommand
        + CancelBookingCommand : ICommand
    }
}

' ============================================
' INTERFACES (ISP - small, focused)
' ============================================
package "Interfaces (ISP + DIP)" as interfaces #E8F5E9 {

    interface IUserRepository <<interface>> {
        + FindById(id) : User
        + Save(user) : void
    }

    interface IUserValidator <<interface>> {
        + Validate(user) : bool
    }

    interface IRoomRepository <<interface>> {
        + FindById(id) : Room
        + GetAvailableRooms() : List<Room>
        + GetAllRooms() : List<Room>
        + Save(room) : void
    }

    interface IRoomPricingService <<interface>> {
        + CalculatePrice(room) : decimal
        + CalculateCleaningCost(room) : decimal
    }

    interface IBookingService <<interface>> {
        + CreateBooking(booking) : BookingResult
        + ConfirmBooking(bookingId) : BookingResult
        + CancelBooking(bookingId) : BookingResult
    }

    interface IBookingRepository <<interface>> {
        + FindById(id) : Booking
        + GetUserBookings(userId) : List<Booking>
        + GetAllBookings() : List<Booking>
        + Save(booking) : void
    }

    interface IBookingDurationCalculator <<interface>> {
        + CalculateDuration(checkIn, checkOut) : int
        + CalculateNights(booking) : int
        + IsLongStay(booking) : bool
    }

    interface IBookingConfirmationService <<interface>> {
        + ConfirmBooking(booking, room) : void
        + CancelBooking(booking, room) : void
        + CompleteBooking(booking, room) : void
    }

    interface ILogger <<interface>> {
        + Info(message) : void
        + Warn(message) : void
        + Error(message) : void
    }
}

' ============================================
' SERVICES (DIP - implement interfaces)
' ============================================
package "Services (DIP implementations)" as services #E3F2FD {

    class InMemoryUserRepository {
        - _users : List<User>
        --
        + FindById(id) : User
        + Save(user) : void
    }

    class UserValidator {
        + Validate(user) : bool
    }

    class InMemoryRoomRepository {
        - _rooms : List<Room>
        --
        + FindById(id) : Room
        + GetAvailableRooms() : List<Room>
        + GetAllRooms() : List<Room>
        + Save(room) : void
    }

    class RoomPricingService {
        + CalculatePrice(room) : decimal
        + CalculateCleaningCost(room) : decimal
    }

    class BookingService {
        - _bookingRepository : IBookingRepository
        - _roomRepository : IRoomRepository
        - _userRepository : IUserRepository
        - _confirmationService : IBookingConfirmationService
        - _userValidator : IUserValidator
        - _logger : ILogger
        --
        + CreateBooking(booking) : BookingResult
        + ConfirmBooking(bookingId) : BookingResult
        + CancelBooking(bookingId) : BookingResult
    }

    class InMemoryBookingRepository {
        - _bookings : List<Booking>
        --
        + FindById(id) : Booking
        + GetUserBookings(userId) : List<Booking>
        + GetAllBookings() : List<Booking>
        + Save(booking) : void
    }

    class BookingDurationCalculator {
        + CalculateDuration(checkIn, checkOut) : int
        + CalculateNights(booking) : int
        + IsLongStay(booking) : bool
    }

    class BookingConfirmationService {
        + ConfirmBooking(booking, room) : void
        + CancelBooking(booking, room) : void
        + CompleteBooking(booking, room) : void
    }

    class ConsoleLogger {
        + Info(message) : void
        + Warn(message) : void
        + Error(message) : void
    }
}

' ============================================
' MODELS - USER HIERARCHY (LSP + OCP)
' ============================================
package "Models: User Hierarchy (LSP + OCP)" as userModels #FFF3E0 {

    abstract class User {
        + Id : string
        + Name : string
        + Email : string
        + Phone : string
        --
        + <<virtual>> GetDisplayInfo() : string
    }

    class Guest {
        + Nationality : string
        + PassportNumber : string
        --
        + <<override>> GetDisplayInfo() : string
    }

    class Admin {
        + Role : string
        + Department : string
        + Permissions : IReadOnlyList<string>
        --
        + <<override>> GetDisplayInfo() : string
    }
}

' ============================================
' MODELS - ROOM HIERARCHY (LSP + OCP)
' ============================================
package "Models: Room Hierarchy (LSP + OCP)" as roomModels #FFF3E0 {

    abstract class Room {
        + RoomId : string
        + RoomNumber : string
        + BasePrice : decimal
        + IsAvailable : bool
        + {abstract} Capacity : int
        --
        + <<virtual>> GetDisplayInfo() : string
        + <<virtual>> GetDescription() : string
        + <<virtual>> SetAvailability(status) : void
    }

    class StandardRoom {
        + <<override>> Capacity : int
        --
        + <<override>> GetDisplayInfo() : string
        + <<override>> GetDescription() : string
        + <<override>> SetAvailability(status) : void
    }

    class DeluxeRoom {
        + <<override>> Capacity : int
        + Amenities : IReadOnlyList<string>
        + HasBalcony : bool
        --
        + <<override>> GetDisplayInfo() : string
        + <<override>> GetDescription() : string
        + <<override>> SetAvailability(status) : void
    }

    class Suite {
        + NumberOfRooms : int
        + HasKitchen : bool
        + HasLivingRoom : bool
        + <<override>> Capacity : int
        --
        + <<override>> GetDisplayInfo() : string
        + <<override>> GetDescription() : string
        + <<override>> SetAvailability(status) : void
    }
}

' ============================================
' MODELS - BOOKING + ENUMS
' ============================================
package "Models: Booking" as bookingModels #F5F5F5 {

    class Booking {
        + BookingId : string
        + UserId : string
        + RoomId : string
        + CheckInDate : DateTime
        + CheckOutDate : DateTime
        + Status : BookingStatus
        --
        + Confirm() : void
        + Cancel() : void
        + Complete() : void
    }

    class BookingResult {
        + Success : bool
        + Message : string
        --
        + {static} Ok(message) : BookingResult
        + {static} Fail(message) : BookingResult
    }

    enum BookingStatus {
        Pending
        Confirmed
        Cancelled
        Completed
    }
}

' ============================================
' LAYOUT: vertical flow
' ============================================
controllers -[hidden]down- interfaces
interfaces -[hidden]down- services
services -[hidden]down- userModels
userModels -[hidden]right- roomModels
roomModels -[hidden]right- bookingModels

BaseViewModel -[hidden]down- GuestController
GuestController -[hidden]right- RoomController
RoomController -[hidden]right- BookingController
BookingController -[hidden]right- LogController
MainViewModel -[hidden]down- GuestController

' ============================================
' INHERITANCE: Controllers
' ============================================
BaseViewModel <|-- GuestController
BaseViewModel <|-- RoomController
BaseViewModel <|-- BookingController
BaseViewModel <|-- LogController
BaseViewModel <|-- MainViewModel

' ============================================
' INHERITANCE: User hierarchy (LSP)
' ============================================
User <|-- Guest
User <|-- Admin

' ============================================
' INHERITANCE: Room hierarchy (LSP)
' ============================================
Room <|-- StandardRoom
Room <|-- DeluxeRoom
Room <|-- Suite

' ============================================
' DIP: Services implement Interfaces
' ============================================
IUserRepository <|.. InMemoryUserRepository
IUserValidator <|.. UserValidator
IRoomRepository <|.. InMemoryRoomRepository
IRoomPricingService <|.. RoomPricingService
IBookingService <|.. BookingService
IBookingRepository <|.. InMemoryBookingRepository
IBookingDurationCalculator <|.. BookingDurationCalculator
IBookingConfirmationService <|.. BookingConfirmationService
ILogger <|.. ConsoleLogger

' ============================================
' DIP: Controllers depend on Interfaces
' ============================================
GuestController --> IUserRepository : depends on
GuestController --> IUserValidator : depends on

RoomController --> IRoomRepository : depends on
RoomController --> IRoomPricingService : depends on

BookingController --> IBookingService : depends on
BookingController --> IBookingRepository : depends on
BookingController --> IBookingDurationCalculator : depends on

LogController --> ILogger : depends on

' ============================================
' DIP: BookingService depends on Interfaces
' ============================================
BookingService --> IBookingRepository : depends on
BookingService --> IRoomRepository : depends on
BookingService --> IUserRepository : depends on
BookingService --> IBookingConfirmationService : depends on
BookingService --> IUserValidator : depends on
BookingService --> ILogger : depends on

' ============================================
' MainViewModel composes controllers
' ============================================
MainViewModel *-- GuestController : composes
MainViewModel *-- RoomController : composes
MainViewModel *-- BookingController : composes
MainViewModel *-- LogController : composes

' ============================================
' Booking uses enum
' ============================================
Booking --> BookingStatus : uses

' ============================================
' NOTES: SOLID PRINCIPLES
' ============================================
note top of controllers
    <b>S — Single Responsibility Principle</b>
    ──────────────────────────────────
    Each controller has ONE job:
    • GuestController → guest registration
    • RoomController → room creation
    • BookingController → booking lifecycle
    • LogController → activity logging
    • MainViewModel → composition root only
end note

note right of roomModels
    <b>L — Liskov Substitution Principle</b>
    ─────────────────────────────────
    ALL virtual/abstract methods overridden
    in EVERY child class:
    • Capacity (abstract) → ✅ all 3
    • GetDisplayInfo() → ✅ all 3
    • GetDescription() → ✅ all 3
    • SetAvailability() → ✅ all 3

    Any child can replace parent
    without breaking behavior.
end note

note right of userModels
    <b>O — Open/Closed Principle</b>
    ────────────────────────
    New user type = new class:
    e.g. Staff : User
    No existing code modified.

    New room type = new class:
    e.g. Penthouse : Room
    No existing code modified.
end note

note top of interfaces
    <b>I — Interface Segregation Principle</b>
    ───────────────────────────────────
    Small, focused interfaces. Controllers
    do NOT use 100% of interface methods:
    • LogController uses ILogger.Info() only
      (not Warn, Error)
    • BookingController uses CalculateNights()
      and IsLongStay() only
      (not CalculateDuration)
    • GuestController uses Save() only
      (not FindById)
end note

note top of services
    <b>D — Dependency Inversion Principle</b>
    ──────────────────────────────────
    Controllers → depend on Interfaces
    Services → implement Interfaces
    Concrete classes created ONLY in
    MainViewModel (Composition Root).

    Controller never knows:
    InMemoryUserRepository, ConsoleLogger,
    BookingService, etc.
end note

@enduml