@startuml Lab2_AbstractFactory

skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam classFontName "Segoe UI"
skinparam defaultFontName "Segoe UI"
skinparam shadowing false
skinparam linetype ortho

skinparam class {
    BackgroundColor #FEFEFE
    BorderColor #546E7A
    ArrowColor #546E7A
    HeaderBackgroundColor #E3F2FD
}
skinparam interface {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
}

title <b>Abstract Factory Pattern — Booking Families</b>

class BookingController {
    - _bookingService : IBookingService
    - _bookingRepository : IBookingRepository
    - _durationCalculator : IBookingDurationCalculator
    - _factoryProvider : BookingFactoryProvider
    + BookingTypes : List<string>
    + SelectedBookingType : string
    + CheckInDate : DateTime
    + CheckOutDate : DateTime
    + Nights : int
    + SelectedBooking : Booking
    + CreateBooking(user, room, pricingService) : void
    + ConfirmBooking() : void
    + CancelBooking() : void
    + RefreshBookings() : void
}

class BookingFactoryProvider {
    - _registry : Dictionary<string, Func<IBookingFactory>>
    + GetFactory(bookingType) : IBookingFactory
    + GetAvailableTypes() : IReadOnlyList<string>
}

interface IBookingFactory {
    + CreateBooking(bookingId, userId, roomId,\n    checkIn, checkOut) : Booking
    + CreatePricingStrategy() : IPricingStrategy
    + CreateConfirmationHandler() : IConfirmationHandler
}

class StandardBookingFactory {
    + CreateBooking(bookingId, userId, roomId,\n    checkIn, checkOut) : Booking
    + CreatePricingStrategy() : IPricingStrategy
    + CreateConfirmationHandler() : IConfirmationHandler
}

class PremiumBookingFactory {
    + CreateBooking(bookingId, userId, roomId,\n    checkIn, checkOut) : Booking
    + CreatePricingStrategy() : IPricingStrategy
    + CreateConfirmationHandler() : IConfirmationHandler
}

class VipBookingFactory {
    + CreateBooking(bookingId, userId, roomId,\n    checkIn, checkOut) : Booking
    + CreatePricingStrategy() : IPricingStrategy
    + CreateConfirmationHandler() : IConfirmationHandler
}

interface IPricingStrategy {
    + CalculateTotalPrice(roomPrice, nights) : decimal
    + GetPricingDescription() : string
}

class StandardPricingStrategy {
    + CalculateTotalPrice(roomPrice, nights) : decimal
    + GetPricingDescription() : string
}

class PremiumPricingStrategy {
    - DiscountRate : decimal = 0.10
    + CalculateTotalPrice(roomPrice, nights) : decimal
    + GetPricingDescription() : string
}

class VipPricingStrategy {
    - DiscountRate : decimal = 0.20
    - FreeNightEvery : int = 5
    + CalculateTotalPrice(roomPrice, nights) : decimal
    + GetPricingDescription() : string
}

interface IConfirmationHandler {
    + GenerateConfirmation(booking, totalPrice) : string
    + GetConfirmationType() : string
}

class StandardConfirmationHandler {
    + GenerateConfirmation(booking, totalPrice) : string
    + GetConfirmationType() : string
}

class PremiumConfirmationHandler {
    + GenerateConfirmation(booking, totalPrice) : string
    + GetConfirmationType() : string
}

class VipConfirmationHandler {
    + GenerateConfirmation(booking, totalPrice) : string
    + GetConfirmationType() : string
}

class Booking {
    + BookingId : string
    + UserId : string
    + RoomId : string
    + CheckInDate : DateTime
    + CheckOutDate : DateTime
    + Status : BookingStatus
    + Confirm() : void
    + Cancel() : void
    + Complete() : void
}

BookingController --> BookingFactoryProvider : uses (injected)
BookingFactoryProvider --> IBookingFactory : returns

IBookingFactory <|.. StandardBookingFactory
IBookingFactory <|.. PremiumBookingFactory
IBookingFactory <|.. VipBookingFactory

IPricingStrategy <|.. StandardPricingStrategy
IPricingStrategy <|.. PremiumPricingStrategy
IPricingStrategy <|.. VipPricingStrategy

IConfirmationHandler <|.. StandardConfirmationHandler
IConfirmationHandler <|.. PremiumConfirmationHandler
IConfirmationHandler <|.. VipConfirmationHandler

StandardBookingFactory ..> Booking                     : <<creates>>
StandardBookingFactory ..> StandardPricingStrategy     : <<creates>>
StandardBookingFactory ..> StandardConfirmationHandler : <<creates>>

PremiumBookingFactory  ..> Booking                     : <<creates>>
PremiumBookingFactory  ..> PremiumPricingStrategy      : <<creates>>
PremiumBookingFactory  ..> PremiumConfirmationHandler  : <<creates>>

VipBookingFactory      ..> Booking                     : <<creates>>
VipBookingFactory      ..> VipPricingStrategy          : <<creates>>
VipBookingFactory      ..> VipConfirmationHandler      : <<creates>>

@enduml
