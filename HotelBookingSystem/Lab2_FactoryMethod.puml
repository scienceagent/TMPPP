@startuml Lab2_Factory_Method

skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam classFontName "Segoe UI"
skinparam defaultFontName "Segoe UI"
skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle

skinparam class {
    BackgroundColor #FEFEFE
    BorderColor #546E7A
    ArrowColor #546E7A
    HeaderBackgroundColor #E3F2FD
}

skinparam interface {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
}

skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

title <b>Laboratory 2 — Factory Method Pattern\nRoom Creation</b>

' ============================================
' CLIENT
' ============================================
class RoomController {
    - _roomFactoryProvider : RoomFactoryProvider
    - _roomRepository : IRoomRepository
    - _roomPricingService : IRoomPricingService
    --
    + CreateRoom() : void
}

' ============================================
' FACTORY PROVIDER
' ============================================
class RoomFactoryProvider {
    - _factories : Dictionary<string, IRoomFactory>
    --
    + GetFactory(roomType) : IRoomFactory
}

' ============================================
' FACTORY INTERFACE
' ============================================
interface IRoomFactory <<interface>> {
    + CreateRoom(roomId, roomNumber,\n    basePrice, capacity) : Room
}

' ============================================
' CONCRETE FACTORIES
' ============================================
class StandardRoomFactory {
    + CreateRoom(roomId, roomNumber,\n    basePrice, capacity) : Room
}

class DeluxeRoomFactory {
    - _defaultAmenities : List<string>
    - _hasBalcony : bool
    --
    + CreateRoom(roomId, roomNumber,\n    basePrice, capacity) : Room
}

class SuiteRoomFactory {
    - _hasKitchen : bool
    - _hasLivingRoom : bool
    --
    + CreateRoom(roomId, roomNumber,\n    basePrice, capacity) : Room
}

' ============================================
' PRODUCT: ABSTRACT
' ============================================
abstract class Room {
    + RoomId : string
    + RoomNumber : string
    + BasePrice : decimal
    + IsAvailable : bool
    + {abstract} Capacity : int
    --
    + <<virtual>> GetDisplayInfo() : string
    + <<virtual>> GetDescription() : string
    + <<virtual>> SetAvailability(status) : void
}

' ============================================
' PRODUCTS: CONCRETE
' ============================================
class StandardRoom {
    + <<override>> Capacity : int
    --
    + <<override>> GetDisplayInfo() : string
    + <<override>> GetDescription() : string
    + <<override>> SetAvailability(status) : void
}

class DeluxeRoom {
    + <<override>> Capacity : int
    + Amenities : IReadOnlyList<string>
    + HasBalcony : bool
    --
    + <<override>> GetDisplayInfo() : string
    + <<override>> GetDescription() : string
    + <<override>> SetAvailability(status) : void
}

class Suite {
    + NumberOfRooms : int
    + HasKitchen : bool
    + HasLivingRoom : bool
    + <<override>> Capacity : int
    --
    + <<override>> GetDisplayInfo() : string
    + <<override>> GetDescription() : string
    + <<override>> SetAvailability(status) : void
}

' ============================================
' RELATIONSHIPS
' ============================================
RoomController --> RoomFactoryProvider : uses
RoomFactoryProvider --> IRoomFactory : selects

IRoomFactory <|.. StandardRoomFactory
IRoomFactory <|.. DeluxeRoomFactory
IRoomFactory <|.. SuiteRoomFactory

StandardRoomFactory ..> StandardRoom : <<creates>>
DeluxeRoomFactory ..> DeluxeRoom : <<creates>>
SuiteRoomFactory ..> Suite : <<creates>>

Room <|-- StandardRoom
Room <|-- DeluxeRoom
Room <|-- Suite

' ============================================
' NOTES
' ============================================
note top of RoomController
    <b>Client</b>
    RoomController never calls
    "new StandardRoom()" directly.
    It asks the factory to create
    the room object.
end note

note right of IRoomFactory
    <b>Factory Method Pattern</b>
    ─────────────────────
    Defines ONE creation method.
    Each concrete factory creates
    ONE specific product type.

    <b>To add new room type:</b>
    1. Create PenthouseRoom : Room
    2. Create PenthouseRoomFactory
    3. Register in Provider
    No existing code modified.
end note

note bottom of Room
    <b>Liskov Substitution</b>
    ALL virtual methods are
    overridden in every child.
    Any child substitutes
    the parent.
end note

@enduml