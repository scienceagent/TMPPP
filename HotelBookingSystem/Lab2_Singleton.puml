@startuml Lab3_Singleton

skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam classFontName "Segoe UI"
skinparam defaultFontName "Segoe UI"
skinparam shadowing false
skinparam linetype ortho

skinparam class {
    BackgroundColor #FEFEFE
    BorderColor #546E7A
    ArrowColor #546E7A
    HeaderBackgroundColor #EDE7F6
}
skinparam interface {
    BackgroundColor #EDE7F6
    BorderColor #6A1B9A
}

title <b>Singleton Pattern — HotelAuditLogger</b>

note as GoFRoles
  <b>GoF Roles</b>
  Singleton → HotelAuditLogger
  (implements ILogger for DI compatibility)
end note

interface ILogger {
    + Info(message)  : void
    + Warn(message)  : void
    + Error(message) : void
}

class HotelAuditLogger implements ILogger {
    - {static} _instance : Lazy<HotelAuditLogger>
    --
    - HotelAuditLogger()
    + {static} Instance : HotelAuditLogger
    + Info(message)  : void
    + Warn(message)  : void
    + Error(message) : void
}

class MainViewModel {
    + SingletonInfo : string
    --
    + MainViewModel()
}

note right of HotelAuditLogger
  <b>Thread-safe via Lazy<T></b>
  private constructor prevents
  external instantiation.
  sealed prevents subclassing.

  var a = HotelAuditLogger.Instance;
  var b = HotelAuditLogger.Instance;
  ReferenceEquals(a, b) == <b>true</b>
end note

note bottom of MainViewModel
  Proof shown live in sidebar:
  "Singleton: same instance = True"
end note

MainViewModel ..> HotelAuditLogger : HotelAuditLogger.Instance

@enduml
