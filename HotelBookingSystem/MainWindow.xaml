<Window x:Class="HotelBookingSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HotelBookingSystem.ViewModels"
        xmlns:converters="clr-namespace:HotelBookingSystem.Converters"
        Title="Hotel Booking System"
        Height="780" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5"
        MinHeight="650" MinWidth="900">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converters:BookingDisplayConverter x:Key="BookingDisplayConverter"/>

        <!-- Sidebar Button Style -->
        <Style x:Key="SidebarButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="Transparent" CornerRadius="6"
                                Padding="14,10" Margin="4,2" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1976D2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#B0BEC5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="GroupName" Value="Navigation"/>
        </Style>

        <!-- Card Style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BorderBrush" Value="#E8E8E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.06" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Background" Value="#B0BEC5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Success Button -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1B5E20"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Background" Value="#B0BEC5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#C62828"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#B71C1C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Background" Value="#B0BEC5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#546E7A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#455A64"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Background" Value="#B0BEC5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Test Button (Amber) -->
        <Style x:Key="TestButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#F57F17"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#E65100"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input Label -->
        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#546E7A"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Input Field -->
        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#CFD8DC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#1976D2"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                    <Setter Property="Background" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Section Title -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#263238"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== SIDEBAR ========== -->
        <Border Grid.Column="0" Background="#263238">
            <DockPanel>
                <!-- Logo / Brand -->
                <StackPanel DockPanel.Dock="Top" Margin="16,24,16,32">
                    <TextBlock Text="H" FontSize="32" FontWeight="Bold" Foreground="#42A5F5"
                               FontFamily="Segoe UI" Margin="0,0,0,4"/>
                    <TextBlock Text="Hotel Booking" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Staff Portal" FontSize="11" Foreground="#78909C" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top" Margin="8,0">
                    <TextBlock Text="M A N A G E M E N T" FontSize="10" Foreground="#607D8B"
                               FontWeight="Bold" Margin="12,0,0,8"/>

                    <RadioButton x:Name="NavNewBooking" Style="{StaticResource SidebarButton}" IsChecked="True">
                        <TextBlock Text="+ New Booking" Foreground="White" FontSize="13"/>
                    </RadioButton>

                    <RadioButton x:Name="NavBookings" Style="{StaticResource SidebarButton}">
                        <TextBlock Text="Bookings" Foreground="White" FontSize="13"/>
                    </RadioButton>

                    <RadioButton x:Name="NavTest" Style="{StaticResource SidebarButton}">
                        <TextBlock Text="Test System" Foreground="White" FontSize="13"/>
                    </RadioButton>

                    <Separator Background="#37474F" Margin="12,16"/>

                    <TextBlock Text="L O G S" FontSize="10" Foreground="#607D8B"
                               FontWeight="Bold" Margin="12,0,0,8"/>

                    <RadioButton x:Name="NavLog" Style="{StaticResource SidebarButton}">
                        <TextBlock Text="Activity Log" Foreground="White" FontSize="13"/>
                    </RadioButton>
                </StackPanel>

                <!-- Footer -->
                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,20" VerticalAlignment="Bottom">
                    <Separator Background="#37474F" Margin="0,0,0,12"/>
                    <TextBlock Text="Logged in as" FontSize="10" Foreground="#607D8B"/>
                    <TextBlock Text="Staff Member" FontSize="12" Foreground="#B0BEC5" FontWeight="Medium"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ========== MAIN CONTENT ========== -->
        <Grid Grid.Column="1" Margin="28,24">

            <!-- PAGE 1: New Booking -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=NavNewBooking}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Page Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="New Booking" FontSize="24" FontWeight="SemiBold" Foreground="#263238"/>
                    <TextBlock Text="Register a guest, assign a room, and create the booking."
                               FontSize="13" Foreground="#78909C" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Content: 3-column layout -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- STEP 1: Guest -->
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="#1976D2" CornerRadius="12" Width="24" Height="24">
                                    <TextBlock Text="1" Foreground="White" FontSize="12" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Guest Details" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#1976D2" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Full Name" Style="{StaticResource InputLabel}"/>
                                    <TextBox Text="{Binding GuestName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputField}" Margin="0,0,0,12"/>

                                    <TextBlock Text="Email Address" Style="{StaticResource InputLabel}"/>
                                    <TextBox Text="{Binding GuestEmail, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputField}" Margin="0,0,0,12"/>

                                    <TextBlock Text="Nationality" Style="{StaticResource InputLabel}"/>
                                    <TextBox Text="{Binding GuestNationality, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputField}" Margin="0,0,0,12"/>

                                    <TextBlock Text="Passport / ID Number" Style="{StaticResource InputLabel}"/>
                                    <TextBox Text="{Binding GuestPassport, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputField}" Margin="0,0,0,16"/>

                                    <Button Content="Register Guest" Command="{Binding CreateGuestCommand}"
                                            Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- STEP 2: Room -->
                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="#1976D2" CornerRadius="12" Width="24" Height="24">
                                    <TextBlock Text="2" Foreground="White" FontSize="12" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Room Assignment" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#1976D2" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Room Number" Style="{StaticResource InputLabel}"/>
                                    <TextBox Text="{Binding RoomNumber, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputField}" Margin="0,0,0,12"/>

                                    <TextBlock Text="Price per Night (USD)" Style="{StaticResource InputLabel}"/>
                                    <TextBox Text="{Binding RoomPrice, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputField}" Margin="0,0,0,12"/>

                                    <TextBlock Text="Capacity (Guests)" Style="{StaticResource InputLabel}"/>
                                    <TextBox Text="{Binding RoomCapacity, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputField}" Margin="0,0,0,12"/>

                                    <TextBlock Text="Room Type" Style="{StaticResource InputLabel}"/>
                                    <ComboBox ItemsSource="{Binding RoomTypes}"
                                              SelectedItem="{Binding SelectedRoomType, Mode=TwoWay}"
                                              Padding="10,8" Margin="0,0,0,16" Background="#FAFAFA"
                                              BorderBrush="#CFD8DC"/>

                                    <Button Content="Assign Room" Command="{Binding CreateRoomCommand}"
                                            Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- STEP 3: Confirm Booking -->
                        <StackPanel Grid.Column="4">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="#2E7D32" CornerRadius="12" Width="24" Height="24">
                                    <TextBlock Text="3" Foreground="White" FontSize="12" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Confirm Booking" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#2E7D32" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <Border Background="#E8F5E9" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Booking Summary" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="#2E7D32" Margin="0,0,0,8"/>
                                            <TextBlock Text="Complete steps 1 and 2 before confirming."
                                                       TextWrapping="Wrap" Foreground="#546E7A" FontSize="12"
                                                       LineHeight="20"/>
                                        </StackPanel>
                                    </Border>

                                    <Button Content="Create Booking" Command="{Binding CreateBookingCommand}"
                                            Style="{StaticResource SuccessButton}" HorizontalAlignment="Stretch"
                                            FontSize="14" Padding="20,14"/>
                                </StackPanel>
                            </Border>

                            <!-- Quick info card -->
                            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="How it works" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#263238" Margin="0,0,0,8"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#78909C" LineHeight="20"
                                               Text="1. Register the guest with valid ID&#x0a;2. Assign an available room&#x0a;3. Confirm to finalize the booking&#x0a;&#x0a;Manage bookings in the Bookings tab."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- PAGE 2: Bookings Management -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=NavBookings}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Booking Management" FontSize="24" FontWeight="SemiBold" Foreground="#263238"/>
                    <TextBlock Text="View, confirm, or cancel existing bookings."
                               FontSize="13" Foreground="#78909C" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Toolbar -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Refresh" Command="{Binding RefreshBookingsCommand}"
                                Style="{StaticResource SecondaryButton}" Padding="16,8"/>
                    </StackPanel>
                </Border>

                <!-- Bookings Table -->
                <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,16">
                    <DataGrid ItemsSource="{Binding Bookings}"
                              SelectedItem="{Binding SelectedBooking, Mode=TwoWay}"
                              IsReadOnly="True" SelectionMode="Single" AutoGenerateColumns="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#ECEFF1"
                              BorderThickness="0" Background="White"
                              RowBackground="White" AlternatingRowBackground="#FAFAFA"
                              Padding="0" Margin="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Booking ID" Width="2*">
                                <DataGridTextColumn.Binding>
                                    <Binding Converter="{StaticResource BookingDisplayConverter}" ConverterParameter="Id"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Status" Width="*">
                                <DataGridTextColumn.Binding>
                                    <Binding Converter="{StaticResource BookingDisplayConverter}" ConverterParameter="Status"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Action buttons -->
                <Border Grid.Row="3" Style="{StaticResource Card}" Padding="16">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Confirm Booking" Command="{Binding ConfirmBookingCommand}"
                                Style="{StaticResource SuccessButton}" Padding="20,10" Margin="0,0,10,0"/>
                        <Button Content="Cancel Booking" Command="{Binding CancelBookingCommand}"
                                Style="{StaticResource DangerButton}" Padding="20,10"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- PAGE 3: Test Polymorphism -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=NavTest}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="System Test" FontSize="24" FontWeight="SemiBold" Foreground="#263238"/>
                    <TextBlock Text="Run polymorphism and SOLID tests to verify system behavior."
                               FontSize="13" Foreground="#78909C" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="This test creates sample Users (Guest, Admin) and Rooms (Standard, Deluxe, Suite) to demonstrate polymorphism, virtual method overrides, and SOLID-compliant service calls."
                                   TextWrapping="Wrap" FontSize="13" Foreground="#546E7A" Margin="0,0,0,16"
                                   LineHeight="20"/>
                        <Button Content="Run Polymorphism Test" Command="{Binding TestPolymorphismCommand}"
                                Style="{StaticResource TestButton}" HorizontalAlignment="Left"
                                FontSize="14" Padding="24,12"/>
                    </StackPanel>
                </Border>

                <!-- Test output -->
                <Border Grid.Row="2" Style="{StaticResource Card}" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Test Output" Style="{StaticResource SectionTitle}"/>
                        <Border Grid.Row="1" Background="#FAFAFA" CornerRadius="6" Padding="16"
                                BorderBrush="#ECEFF1" BorderThickness="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                          MaxHeight="400">
                                <TextBlock Text="{Binding LogOutput}" TextWrapping="Wrap"
                                           FontFamily="Cascadia Code, Consolas, Courier New"
                                           FontSize="12" Foreground="#37474F" LineHeight="20"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- PAGE 4: Activity Log -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=NavLog}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Activity Log" FontSize="24" FontWeight="SemiBold" Foreground="#263238"/>
                    <TextBlock Text="Full log of all system actions and events."
                               FontSize="13" Foreground="#78909C" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16">
                    <Border Background="#263238" CornerRadius="8" Padding="20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding LogOutput}" TextWrapping="Wrap"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="12" Foreground="#A5D6A7" LineHeight="20"/>
                        </ScrollViewer>
                    </Border>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>