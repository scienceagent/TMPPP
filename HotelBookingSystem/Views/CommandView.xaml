<UserControl x:Class="HotelBookingSystem.Views.CommandView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <Style x:Key="ICard" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="20"/>
            <Setter Property="BorderBrush"     Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OpBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Background" Value="#CBD5E1"/>
                                <Setter Property="Foreground"               Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FLbl" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,32">

            <!-- ══════ HEADER ══════ -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Background="#0F172A" CornerRadius="4" Padding="8,3" Margin="0,0,10,0">
                            <TextBlock Text="LAB 6 · COMMAND" FontSize="10" FontWeight="Bold" Foreground="#A78BFA"/>
                        </Border>
                        <TextBlock Text="Operations Console"
                                   FontSize="24" FontWeight="SemiBold" Foreground="#0F172A"/>
                    </StackPanel>
                    <TextBlock FontSize="12" Foreground="#64748B" TextWrapping="Wrap">
                        <Run>Every hotel operation is encapsulated as a Command object.</Run>
                        <Run>Invoker (</Run><Run FontFamily="Cascadia Code, Consolas" FontSize="11">BookingCommandInvoker</Run>
                        <Run>) maintains Undo/Redo stacks and supports atomic transactions with automatic rollback.</Run>
                        <Run FontWeight="SemiBold"> The Invoker never knows what the commands do.</Run>
                    </TextBlock>
                </StackPanel>

                <!-- Undo/Redo counter badges -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#FEF3C7" CornerRadius="8" Padding="14,10" Margin="0,0,10,0"
                            BorderBrush="#FDE68A" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="UNDO STACK" FontSize="9" FontWeight="Bold"
                                       Foreground="#92400E" Margin="0,0,0,3" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding CommandCtrl.UndoCount}"
                                       FontSize="28" FontWeight="Bold" Foreground="#D97706"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#EFF6FF" CornerRadius="8" Padding="14,10"
                            BorderBrush="#BFDBFE" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="REDO STACK" FontSize="9" FontWeight="Bold"
                                       Foreground="#1E3A8A" Margin="0,0,0,3" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding CommandCtrl.RedoCount}"
                                       FontSize="28" FontWeight="Bold" Foreground="#2563EB"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ══════ INVOKER CONTROLS ══════ -->
            <Border Style="{StaticResource ICard}" Padding="16,14" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Undo -->
                    <Button Grid.Column="0" Content="↩  Undo"
                            Command="{Binding CommandCtrl.UndoCommand}"
                            Background="#D97706" Style="{StaticResource OpBtn}" Padding="18,10"/>

                    <!-- Redo -->
                    <Button Grid.Column="2" Content="↪  Redo"
                            Command="{Binding CommandCtrl.RedoCommand}"
                            Background="#2563EB" Style="{StaticResource OpBtn}" Padding="18,10"/>

                    <!-- Undo All -->
                    <Button Grid.Column="4" Content="↩↩  Undo All"
                            Command="{Binding CommandCtrl.UndoAllCommand}"
                            Background="#64748B" Style="{StaticResource OpBtn}" Padding="18,10"/>

                    <!-- Status message -->
                    <Border Grid.Column="5" Background="#F8FAFC" CornerRadius="6"
                            Padding="14,10" Margin="12,0">
                        <TextBlock Text="{Binding CommandCtrl.StatusMessage}"
                                   FontSize="12" Foreground="#374151"
                                   VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Refresh -->
                    <Button Grid.Column="6" Content="↻  Refresh"
                            Command="{Binding CommandCtrl.RefreshCommand}"
                            Background="#475569" Style="{StaticResource OpBtn}" Padding="14,10"/>
                </Grid>
            </Border>

            <!-- ══════ MAIN GRID: Operations + Info ══════ -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Operations panel -->
                <StackPanel Grid.Column="0">

                    <!-- Selected booking info strip -->
                    <Border Background="#F0F9FF" CornerRadius="8" Padding="14,10"
                            BorderBrush="#BAE6FD" BorderThickness="1" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="SELECTED:" FontSize="10" FontWeight="Bold"
                                       Foreground="#0369A1" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding CommandCtrl.SelectedBookingInfo}"
                                       FontSize="12" Foreground="#0369A1" VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Border>

                    <!-- ── SECTION 1: Booking operations ── -->
                    <Border Style="{StaticResource ICard}" Margin="0,0,0,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Background="#2563EB" CornerRadius="4" Padding="7,3" Margin="0,0,8,0">
                                    <TextBlock Text="BOOKING COMMANDS" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="ConfirmBookingCommand · CancelBookingCommand"
                                           FontSize="10" Foreground="#64748B"
                                           FontFamily="Cascadia Code, Consolas"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="SELECT BOOKING" Style="{StaticResource FLbl}"/>
                            <ComboBox ItemsSource="{Binding CommandCtrl.BookingIds}"
                                      SelectedItem="{Binding CommandCtrl.SelectedBookingId, Mode=TwoWay}"
                                      Padding="10,9" Background="#FAFBFC"
                                      BorderBrush="#E2E8F0" Margin="0,0,0,16">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="11">
                                            <Run Text="{Binding Mode=OneWay}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="✓  Confirm Booking"
                                        Command="{Binding CommandCtrl.ConfirmBookingCommand}"
                                        Background="#15803D" Style="{StaticResource OpBtn}"
                                        Padding="18,10" Margin="0,0,10,0"/>
                                <Button Content="✕  Cancel Booking"
                                        Command="{Binding CommandCtrl.CancelBookingCommand}"
                                        Background="#DC2626" Style="{StaticResource OpBtn}"
                                        Padding="18,10"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── SECTION 2: Room price command ── -->
                    <Border Style="{StaticResource ICard}" Margin="0,0,0,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Background="#7C3AED" CornerRadius="4" Padding="7,3" Margin="0,0,8,0">
                                    <TextBlock Text="ROOM COMMAND" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="AdjustRoomPriceCommand (stores price snapshot for Undo)"
                                           FontSize="10" Foreground="#64748B"
                                           FontFamily="Cascadia Code, Consolas"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="SELECT ROOM" Style="{StaticResource FLbl}"/>
                                    <ComboBox ItemsSource="{Binding CommandCtrl.RoomIds}"
                                              SelectedItem="{Binding CommandCtrl.SelectedRoomId, Mode=TwoWay}"
                                              Padding="10,9" Background="#FAFBFC" BorderBrush="#E2E8F0">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="11"
                                                           Text="{Binding Mode=OneWay}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="NEW PRICE ($/night)" Style="{StaticResource FLbl}"/>
                                    <TextBox Text="{Binding CommandCtrl.NewRoomPrice,
                                                            Converter={StaticResource DecimalInputConverter},
                                                            UpdateSourceTrigger=LostFocus}"
                                             Padding="10,9" BorderBrush="#E2E8F0" Background="#FAFBFC"/>
                                </StackPanel>
                            </Grid>

                            <Button Content="💰  Adjust Room Price"
                                    Command="{Binding CommandCtrl.AdjustPriceCommand}"
                                    Background="#7C3AED" Style="{StaticResource OpBtn}" Padding="18,10"/>
                        </StackPanel>
                    </Border>

                    <!-- ── SECTION 3: Macro command ── -->
                    <Border Style="{StaticResource ICard}" Margin="0,0,0,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Background="#DC2626" CornerRadius="4" Padding="7,3" Margin="0,0,8,0">
                                    <TextBlock Text="MACRO COMMAND" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="RebookGuestCommand = CancelBooking + CreateBooking (atomic Undo)"
                                           FontSize="10" Foreground="#64748B"
                                           FontFamily="Cascadia Code, Consolas"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                            <TextBlock FontSize="11" Foreground="#64748B" TextWrapping="Wrap" Margin="0,0,0,14"
                                       Text="Selects booking above + target room below. Atomically cancels original and creates a new booking on the target room. A single Undo() reverses both steps."/>

                            <Button Content="🔄  Rebook Guest (Macro)"
                                    Command="{Binding CommandCtrl.RebookCommand}"
                                    Background="#DC2626" Style="{StaticResource OpBtn}" Padding="18,10"/>
                        </StackPanel>
                    </Border>

                    <!-- ── SECTION 4: Transaction demo ── -->
                    <Border Style="{StaticResource ICard}" Padding="0">
                        <StackPanel>
                            <Border Background="#0F172A" CornerRadius="10,10,0,0" Padding="16,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="ATOMIC TRANSACTION DEMO" FontSize="11"
                                               FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text=" — ExecuteTransaction() with automatic rollback"
                                               FontSize="10" Foreground="#64748B"
                                               FontFamily="Cascadia Code, Consolas" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <StackPanel Margin="20,16">
                                <TextBlock FontSize="11" Foreground="#64748B" TextWrapping="Wrap" Margin="0,0,0,14"
                                           Text="Runs two scenarios: (A) a successful multi-step transaction, (B) a failing transaction that auto-rolls back all completed steps in reverse order. Requires at least 1 booking."/>
                                <Button Content="⚡  Run Transaction Demo"
                                        Command="{Binding CommandCtrl.DemoTransactionCommand}"
                                        Background="#0F172A" Style="{StaticResource OpBtn}" Padding="18,10"
                                        HorizontalAlignment="Left" Margin="0,0,0,14"/>
                                <Border Background="#0F172A" CornerRadius="8" Padding="16" MinHeight="60">
                                    <TextBlock Text="{Binding CommandCtrl.TransactionResult}"
                                               FontFamily="Cascadia Code, Consolas"
                                               FontSize="12" Foreground="#7DD3FC"
                                               TextWrapping="Wrap" LineHeight="20"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- Pattern info panel -->
                <Border Grid.Column="2" Style="{StaticResource ICard}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="PATTERN STRUCTURE" FontSize="10" FontWeight="Bold"
                                   Foreground="#64748B" Margin="0,0,0,12"/>

                        <Border Background="#F8FAFC" CornerRadius="8" Padding="14,12"
                                BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,16">
                            <TextBlock FontFamily="Cascadia Code, Consolas"
                                       FontSize="10" Foreground="#0F172A" LineHeight="18">
                                <Run>IHotelCommand</Run><LineBreak/>
                                <Run>  Execute()</Run><LineBreak/>
                                <Run>  Undo()</Run><LineBreak/>
                                <Run>  CanUndo : bool</Run><LineBreak/>
                                <Run>  Description, Category</Run><LineBreak/>
                                <LineBreak/>
                                <Run>Concrete commands:</Run><LineBreak/>
                                <Run>  CreateBookingCommand</Run><LineBreak/>
                                <Run>  ConfirmBookingCommand</Run><LineBreak/>
                                <Run>  CancelBookingCommand</Run><LineBreak/>
                                <Run>  AdjustRoomPriceCommand</Run><LineBreak/>
                                <Run>  RebookGuestCommand</Run><LineBreak/>
                                <Run>    (Macro: 2 sub-commands)</Run><LineBreak/>
                                <LineBreak/>
                                <Run>Receiver:</Run><LineBreak/>
                                <Run>  BookingOperationReceiver</Run><LineBreak/>
                                <LineBreak/>
                                <Run>Invoker:</Run><LineBreak/>
                                <Run>  BookingCommandInvoker</Run><LineBreak/>
                                <Run>  Execute() / Undo() / Redo()</Run><LineBreak/>
                                <Run>  ExecuteTransaction()</Run>
                            </TextBlock>
                        </Border>

                        <TextBlock Text="SOLID ANALYSIS" FontSize="10" FontWeight="Bold"
                                   Foreground="#64748B" Margin="0,0,0,10"/>

                        <Border Background="#F0FDF4" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="S ✓  Single Responsibility" FontSize="11"
                                           FontWeight="SemiBold" Foreground="#15803D"/>
                                <TextBlock FontSize="10" Foreground="#374151" TextWrapping="Wrap"
                                           Text="Each command encapsulates ONE operation + its exact inverse. Invoker only manages stacks."/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F0FDF4" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="O ✓  Open / Closed" FontSize="11"
                                           FontWeight="SemiBold" Foreground="#15803D"/>
                                <TextBlock FontSize="10" Foreground="#374151" TextWrapping="Wrap"
                                           Text="Add command 6 (CheckInCommand) with zero changes to Invoker or any existing command."/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F0FDF4" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="D ✓  Dependency Inversion" FontSize="11"
                                           FontWeight="SemiBold" Foreground="#15803D"/>
                                <TextBlock FontSize="10" Foreground="#374151" TextWrapping="Wrap"
                                           Text="Invoker depends on IHotelCommand — never on ConfirmBookingCommand or any concrete class."/>
                            </StackPanel>
                        </Border>
                        <Border Background="#EFF6FF" CornerRadius="6" Padding="10,8">
                            <StackPanel>
                                <TextBlock Text="vs. direct method calls" FontSize="11"
                                           FontWeight="SemiBold" Foreground="#1D4ED8"/>
                                <TextBlock FontSize="10" Foreground="#374151" TextWrapping="Wrap"
                                           Text="Without Command, Undo requires the UI to know how to reverse each operation — spreading reversal logic across ViewModels."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════ COMMAND HISTORY TABLE ══════ -->
            <Border Style="{StaticResource ICard}" Padding="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#4F46E5"
                            CornerRadius="10,10,0,0" Padding="16,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📜" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="COMMAND HISTORY" FontSize="11" FontWeight="Bold"
                                       Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text=" — full audit trail  ·  newest first"
                                       FontSize="10" Foreground="#A5B4FC"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <DataGrid DockPanel.Dock="Bottom"
                              ItemsSource="{Binding CommandCtrl.HistoryRows}"
                              IsReadOnly="True" AutoGenerateColumns="False"
                              BorderThickness="0" Background="White"
                              RowBackground="White" AlternatingRowBackground="#FAFBFC"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                              HeadersVisibility="Column" SelectionMode="Single"
                              MaxHeight="300" ScrollViewer.VerticalScrollBarVisibility="Auto">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"      Value="#F8FAFC"/>
                                <Setter Property="Foreground"      Value="#64748B"/>
                                <Setter Property="FontSize"        Value="10"/>
                                <Setter Property="FontWeight"      Value="Bold"/>
                                <Setter Property="Padding"         Value="12,8"/>
                                <Setter Property="BorderBrush"     Value="#E2E8F0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>

                            <!-- Time -->
                            <DataGridTextColumn Header="Time" Width="66"
                                                Binding="{Binding TimestampFmt}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="Cascadia Code, Consolas"/>
                                        <Setter Property="FontSize"   Value="10"/>
                                        <Setter Property="Foreground" Value="#64748B"/>
                                        <Setter Property="Margin"     Value="12,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Status badge -->
                            <DataGridTemplateColumn Header="Status" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusColor}"
                                                CornerRadius="4" Padding="6,2"
                                                Margin="8,4" VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding StatusIcon}"
                                                           FontSize="10" Foreground="White"
                                                           Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding Status}"
                                                           FontSize="8" FontWeight="Bold"
                                                           Foreground="White"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Category badge -->
                            <DataGridTemplateColumn Header="Category" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding CategoryColor}"
                                                CornerRadius="4" Padding="6,2"
                                                Margin="8,4" VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="8" FontWeight="Bold"
                                                       Foreground="White"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Description" Width="*"
                                                Binding="{Binding FullDescription}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontSize"          Value="11"/>
                                        <Setter Property="Foreground"        Value="#374151"/>
                                        <Setter Property="Margin"            Value="12,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Undo-able indicator -->
                            <DataGridTemplateColumn Header="Undo?" Width="58">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value="✓"/>
                                                    <Setter Property="Foreground" Value="#15803D"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CanUndo}" Value="False">
                                                            <Setter Property="Text"       Value="—"/>
                                                            <Setter Property="Foreground" Value="#CBD5E1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
