<UserControl x:Class="HotelBookingSystem.Views.FacadeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,24">

            <StackPanel Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Border Background="#6A1B9A" CornerRadius="4" Padding="8,3" Margin="0,0,10,0">
                        <TextBlock Text="FAÇADE" FontSize="10" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <TextBlock Text="Hotel Operations" FontSize="24" FontWeight="SemiBold" Foreground="#263238"/>
                </StackPanel>
                <TextBlock FontSize="12" Foreground="#78909C" TextWrapping="Wrap"
                           Text="HotelFacade hides the complexity of 6 subsystems behind 3 simple calls. CheckInGuest orchestrates booking validation + Adapter payment + Singleton logging. CheckOutGuest sums room services via Composite + charges via Adapter + releases room."/>
            </StackPanel>

            <Border Background="White" CornerRadius="10" Padding="20"
                    BorderBrush="#E8E8E8" BorderThickness="1" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="HotelFacade — what each call orchestrates internally"
                               FontSize="13" FontWeight="SemiBold" Foreground="#263238" Margin="0,0,0,14"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#EDE7F6" CornerRadius="8" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="CheckInGuest(bookingId)" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#6A1B9A" Margin="0,0,0,10" FontFamily="Consolas"/>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Border Background="#546E7A" CornerRadius="3" Padding="4,1" Margin="0,0,6,0">
                                        <TextBlock Text="1" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="Validate booking status" FontSize="11" Foreground="#263238" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Border Background="#546E7A" CornerRadius="3" Padding="4,1" Margin="0,0,6,0">
                                        <TextBlock Text="2" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="Find room + guest" FontSize="11" Foreground="#263238" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Border Background="#1565C0" CornerRadius="3" Padding="4,1" Margin="0,0,6,0">
                                        <TextBlock Text="3" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="ProcessPayment → [Adapter]" FontSize="11"
                                               Foreground="#1565C0" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Border Background="#6A1B9A" CornerRadius="3" Padding="4,1" Margin="0,0,6,0">
                                        <TextBlock Text="4" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="Log → [Singleton]" FontSize="11"
                                               Foreground="#6A1B9A" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#FCE4EC" CornerRadius="8" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="CheckOutGuest(bookingId, services)" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#880E4F" Margin="0,0,0,10" FontFamily="Consolas"/>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Border Background="#546E7A" CornerRadius="3" Padding="4,1" Margin="0,0,6,0">
                                        <TextBlock Text="1" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="Find booking" FontSize="11" Foreground="#263238" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Border Background="#00695C" CornerRadius="3" Padding="4,1" Margin="0,0,6,0">
                                        <TextBlock Text="2" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="Sum services → [Composite]" FontSize="11"
                                               Foreground="#00695C" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Border Background="#1565C0" CornerRadius="3" Padding="4,1" Margin="0,0,6,0">
                                        <TextBlock Text="3" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="Charge services → [Adapter]" FontSize="11"
                                               Foreground="#1565C0" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Border Background="#6A1B9A" CornerRadius="3" Padding="4,1" Margin="0,0,6,0">
                                        <TextBlock Text="4" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="Release room + Log → [Singleton]" FontSize="11"
                                               Foreground="#6A1B9A" VerticalAlignment="Center" FontWeight="Medium"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="10" Padding="20"
                    BorderBrush="#E8E8E8" BorderThickness="1" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Execute hotel operations" FontSize="13" FontWeight="SemiBold"
                               Foreground="#263238" Margin="0,0,0,14"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="Booking" Foreground="#546E7A" FontSize="12"
                                   FontWeight="Medium" VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="70"/>
                        <ComboBox ItemsSource="{Binding FacadeCtrl.BookingIds}"
                                  SelectedItem="{Binding FacadeCtrl.SelectedBookingId, Mode=TwoWay}"
                                  MinWidth="300" Padding="10,8" BorderBrush="#CFD8DC" Background="#FAFAFA"/>
                        <Button Content="↻ Refresh" Command="{Binding RefreshFacadeCommand}"
                                Margin="10,0,0,0" Padding="12,8" BorderThickness="0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#546E7A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#455A64"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="✓  Check In Guest" Command="{Binding CheckInCommand}"
                                Padding="22,12" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#2E7D32"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#1B5E20"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bg" Property="Background" Value="#B0BEC5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="←  Check Out Guest" Command="{Binding CheckOutCommand}"
                                Padding="22,12" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#C62828"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#B71C1C"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bg" Property="Background" Value="#B0BEC5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Summary" Command="{Binding ShowSummaryCommand}"
                                Padding="22,12" BorderThickness="0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#546E7A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#455A64"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bg" Property="Background" Value="#B0BEC5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <Border Background="#263238" CornerRadius="8" Padding="18" MinHeight="100">
                        <TextBlock Text="{Binding FacadeCtrl.FacadeResult}"
                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                   FontSize="12" Foreground="#A5D6A7"
                                   TextWrapping="Wrap" LineHeight="20"/>
                    </Border>

                    <Border Background="#FFF8E1" CornerRadius="6" Padding="12,10" Margin="0,10,0,0">
                        <TextBlock FontSize="11" Foreground="#795548" TextWrapping="Wrap">
                            <Run FontWeight="Bold">Workflow tip:</Run>
                            <Run>1. Create a booking on the New Booking page.  2. Confirm it on the Bookings page.  3. Optionally add room services on the Room Services page.  4. Come here to Check In (charges room cost) or Check Out (charges services + releases room).</Run>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
