<UserControl x:Class="HotelBookingSystem.Views.IteratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <UserControl.Resources>
        <Style x:Key="ICard" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="20"/>
            <Setter Property="BorderBrush"     Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RptBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FLbl" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,32">

            <!-- ══════ HEADER ══════ -->
            <StackPanel Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Border Background="#0F172A" CornerRadius="4" Padding="8,3" Margin="0,0,10,0">
                        <TextBlock Text="LAB 6 · ITERATOR" FontSize="10" FontWeight="Bold" Foreground="#34D399"/>
                    </Border>
                    <TextBlock Text="Reports &amp; Analytics"
                               FontSize="24" FontWeight="SemiBold" Foreground="#0F172A"/>
                </StackPanel>
                <TextBlock FontSize="12" Foreground="#64748B" TextWrapping="Wrap">
                    <Run>Six independent traversal strategies over the same </Run>
                    <Run FontFamily="Cascadia Code, Consolas" FontSize="11">BookingCollection</Run>
                    <Run>. The </Run>
                    <Run FontFamily="Cascadia Code, Consolas" FontSize="11">BookingReportEngine</Run>
                    <Run> (client) only calls </Run>
                    <Run FontFamily="Cascadia Code, Consolas" FontSize="11">HasNext() / Next()</Run>
                    <Run> — it never knows the collection's internal structure.</Run>
                </TextBlock>
            </StackPanel>

            <!-- ══════ MAIN LAYOUT ══════ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── LEFT: Report buttons + params ─── -->
                <StackPanel Grid.Column="0">

                    <!-- Total counter -->
                    <Border Background="#F0FDF4" CornerRadius="8" Padding="14,10"
                            BorderBrush="#BBF7D0" BorderThickness="1" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="COLLECTION" FontSize="9" FontWeight="Bold"
                                       Foreground="#15803D" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding IteratorCtrl.TotalBookingsDisplay}"
                                       FontSize="11" Foreground="#15803D" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Report buttons ── -->
                    <Border Style="{StaticResource ICard}" Padding="14,16">
                        <StackPanel>
                            <TextBlock Text="REPORTS" FontSize="10" FontWeight="Bold"
                                       Foreground="#64748B" Margin="0,0,0,12"/>

                            <Button Content="📋  Summary Report"
                                    Command="{Binding IteratorCtrl.GenerateSummaryCommand}"
                                    Background="#2563EB" Style="{StaticResource RptBtn}"
                                    Padding="12,10" Margin="0,0,0,6"
                                    HorizontalAlignment="Stretch"/>

                            <Button Content="📅  Occupancy Timeline"
                                    Command="{Binding IteratorCtrl.GenerateTimelineCommand}"
                                    Background="#0891B2" Style="{StaticResource RptBtn}"
                                    Padding="12,10" Margin="0,0,0,6"
                                    HorizontalAlignment="Stretch"/>

                            <Button Content="💰  Revenue by Type"
                                    Command="{Binding IteratorCtrl.GenerateRevenueCommand}"
                                    Background="#15803D" Style="{StaticResource RptBtn}"
                                    Padding="12,10" Margin="0,0,0,6"
                                    HorizontalAlignment="Stretch"/>

                            <Button Content="🏷  Status Report"
                                    Command="{Binding IteratorCtrl.GenerateStatusCommand}"
                                    Background="#7C3AED" Style="{StaticResource RptBtn}"
                                    Padding="12,10" Margin="0,0,0,6"
                                    HorizontalAlignment="Stretch"/>

                            <Separator Background="#E2E8F0" Margin="0,8,0,8"/>

                            <!-- Parameterised: Recent N -->
                            <TextBlock Text="RECENT COUNT" Style="{StaticResource FLbl}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBox Text="{Binding IteratorCtrl.RecentCount,
                                                         UpdateSourceTrigger=LostFocus}"
                                         Width="50" Padding="7,7" BorderBrush="#E2E8F0"
                                         Background="#FAFBFC" FontSize="12"/>
                                <Button Content="⏱  Recent N"
                                        Command="{Binding IteratorCtrl.GenerateRecentCommand}"
                                        Background="#F59E0B" Style="{StaticResource RptBtn}"
                                        Padding="10,8" Margin="6,0,0,0"/>
                            </StackPanel>

                            <!-- Parameterised: Date range -->
                            <TextBlock Text="DATE RANGE" Style="{StaticResource FLbl}" Margin="0,8,0,4"/>
                            <DatePicker SelectedDate="{Binding IteratorCtrl.RangeFrom, Mode=TwoWay}"
                                        Padding="7,7" Margin="0,0,0,5"
                                        DisplayDateStart="{x:Static sys:DateTime.Today}"/>
                            <DatePicker SelectedDate="{Binding IteratorCtrl.RangeTo, Mode=TwoWay}"
                                        Padding="7,7" Margin="0,0,0,6"/>
                            <Button Content="📆  Date Range"
                                    Command="{Binding IteratorCtrl.GenerateDateRangeCommand}"
                                    Background="#059669" Style="{StaticResource RptBtn}"
                                    Padding="12,10" HorizontalAlignment="Stretch"/>

                            <Separator Background="#E2E8F0" Margin="0,10,0,10"/>

                            <Button Content="↻  Refresh Stats"
                                    Command="{Binding IteratorCtrl.RefreshStatsCommand}"
                                    Background="#475569" Style="{StaticResource RptBtn}"
                                    Padding="12,9" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ─── RIGHT: Report output + Stats ─── -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Report terminal -->
                    <Border Grid.Row="0" Style="{StaticResource ICard}" Padding="0">
                        <DockPanel>
                            <!-- Terminal title bar -->
                            <Border DockPanel.Dock="Top" Background="#0F172A"
                                    CornerRadius="10,10,0,0" Padding="16,11">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="10" Height="10" Fill="#EF4444" Margin="0,0,5,0"/>
                                    <Ellipse Width="10" Height="10" Fill="#F59E0B" Margin="0,0,5,0"/>
                                    <Ellipse Width="10" Height="10" Fill="#10B981" Margin="0,0,14,0"/>
                                    <TextBlock FontSize="11" Foreground="#64748B"
                                               FontFamily="Cascadia Code, Consolas"
                                               VerticalAlignment="Center">
                                        <Run Text="BookingReportEngine  →  "/>
                                        <Run Text="{Binding IteratorCtrl.ActiveReport}"
                                             Foreground="#7DD3FC"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <!-- Output -->
                            <Border DockPanel.Dock="Bottom" Background="#0F172A"
                                    CornerRadius="0,0,10,10" MinHeight="400">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto"
                                              MaxHeight="460">
                                    <TextBlock Text="{Binding IteratorCtrl.ReportOutput}"
                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                               FontSize="12" Foreground="#7DD3FC"
                                               TextWrapping="NoWrap" LineHeight="20"
                                               Margin="20"/>
                                </ScrollViewer>
                            </Border>
                        </DockPanel>
                    </Border>

                    <!-- Iterator stats grid -->
                    <Border Grid.Row="2" Style="{StaticResource ICard}" Padding="0">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#059669"
                                    CornerRadius="10,10,0,0" Padding="16,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="ITERATOR STATISTICS — live counts per iterator"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <DataGrid DockPanel.Dock="Bottom"
                                      ItemsSource="{Binding IteratorCtrl.IteratorStats}"
                                      IsReadOnly="True" AutoGenerateColumns="False"
                                      BorderThickness="0" Background="White"
                                      RowBackground="White" AlternatingRowBackground="#F0FDF4"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#DCFCE7"
                                      HeadersVisibility="Column" SelectionMode="Single"
                                      MaxHeight="220">

                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background"      Value="#F8FAFC"/>
                                        <Setter Property="Foreground"      Value="#64748B"/>
                                        <Setter Property="FontSize"        Value="10"/>
                                        <Setter Property="FontWeight"      Value="Bold"/>
                                        <Setter Property="Padding"         Value="12,8"/>
                                        <Setter Property="BorderBrush"     Value="#E2E8F0"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>

                                <DataGrid.Columns>

                                    <!-- Coloured name badge -->
                                    <DataGridTemplateColumn Header="Iterator" Width="190">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding ColorHex}"
                                                        CornerRadius="4" Padding="7,2"
                                                        Margin="8,3" HorizontalAlignment="Left"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding IteratorName}"
                                                               FontSize="9" FontWeight="Bold"
                                                               Foreground="White"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="Count" Width="56"
                                                        Binding="{Binding TotalElements}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight"      Value="Bold"/>
                                                <Setter Property="FontSize"        Value="13"/>
                                                <Setter Property="Foreground"      Value="#0F172A"/>
                                                <Setter Property="Margin"          Value="12,0"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Filter / Description" Width="*"
                                                        Binding="{Binding Description}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize"          Value="11"/>
                                                <Setter Property="Foreground"        Value="#64748B"/>
                                                <Setter Property="Margin"            Value="12,0"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ══════ PATTERN NOTE ══════ -->
            <Border Style="{StaticResource ICard}" Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PATTERN STRUCTURE" FontSize="10" FontWeight="Bold"
                                   Foreground="#64748B" Margin="0,0,0,10"/>
                        <Border Background="#F8FAFC" CornerRadius="8" Padding="14,12"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <TextBlock FontFamily="Cascadia Code, Consolas"
                                       FontSize="10" Foreground="#0F172A" LineHeight="18">
                                <Run>IBookingIterator</Run><LineBreak/>
                                <Run>  HasNext() / Next() / Reset()</Run><LineBreak/>
                                <Run>  Peek() / CurrentIndex / TotalCount</Run><LineBreak/>
                                <LineBreak/>
                                <Run>Concrete iterators:</Run><LineBreak/>
                                <Run>  SequentialBookingIterator</Run><LineBreak/>
                                <Run>  ChronologicalBookingIterator</Run><LineBreak/>
                                <Run>  StatusFilterIterator</Run><LineBreak/>
                                <Run>  DateRangeIterator</Run><LineBreak/>
                                <Run>  RecentBookingsIterator</Run><LineBreak/>
                                <Run>  TypeFilterIterator</Run><LineBreak/>
                                <LineBreak/>
                                <Run>IBookingCollection (Aggregate)</Run><LineBreak/>
                                <Run>  BookingCollection</Run><LineBreak/>
                                <Run>  → factory methods per iterator</Run><LineBreak/>
                                <Run>  → IEnumerable for native foreach</Run><LineBreak/>
                                <LineBreak/>
                                <Run>BookingReportEngine (Client)</Run><LineBreak/>
                                <Run>  uses only HasNext()/Next()</Run><LineBreak/>
                                <Run>  never sees List or repository</Run>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="SOLID ANALYSIS" FontSize="10" FontWeight="Bold"
                                   Foreground="#64748B" Margin="0,0,0,10"/>

                        <Border Background="#F0FDF4" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="S ✓  Single Responsibility" FontSize="11"
                                           FontWeight="SemiBold" Foreground="#15803D"/>
                                <TextBlock FontSize="10" Foreground="#374151" TextWrapping="Wrap"
                                           Text="BookingCollection manages storage. Each iterator manages exactly one traversal strategy. BookingReportEngine manages formatting."/>
                            </StackPanel>
                        </Border>

                        <Border Background="#F0FDF4" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="O ✓  Open / Closed" FontSize="11"
                                           FontWeight="SemiBold" Foreground="#15803D"/>
                                <TextBlock FontSize="10" Foreground="#374151" TextWrapping="Wrap"
                                           Text="Add a 7th iterator (ReverseChronologicalIterator) without modifying BookingCollection or BookingReportEngine."/>
                            </StackPanel>
                        </Border>

                        <Border Background="#F0FDF4" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="D ✓  Dependency Inversion" FontSize="11"
                                           FontWeight="SemiBold" Foreground="#15803D"/>
                                <TextBlock FontSize="10" Foreground="#374151" TextWrapping="Wrap"
                                           Text="BookingReportEngine depends on IBookingIterator (abstraction). It never imports List, IQueryable, or IBookingRepository."/>
                            </StackPanel>
                        </Border>

                        <Border Background="#EFF6FF" CornerRadius="6" Padding="10,8">
                            <StackPanel>
                                <TextBlock Text="C# IEnumerable integration" FontSize="11"
                                           FontWeight="SemiBold" Foreground="#1D4ED8"/>
                                <TextBlock FontSize="10" Foreground="#374151" TextWrapping="Wrap"
                                           Text="BookingCollection also implements IEnumerable so native C# foreach works: foreach (var b in collection) { }. Both styles coexist — explicit iterator for reports, foreach for simple loops."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
