<UserControl x:Class="HotelBookingSystem.Views.StaffLoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <RadialGradientBrush x:Key="LoginSidebarBrush" GradientOrigin="0.5,0.1" Center="0.5,0.1" RadiusX="0.8" RadiusY="0.8">
            <GradientStop Color="#162E44" Offset="0"/>
            <GradientStop Color="#0B1C2C" Offset="1"/>
        </RadialGradientBrush>
    </UserControl.Resources>

    <Grid Background="{StaticResource SurfaceDimBrush}">
        <!-- Main Enterprise Login Card -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center" 
                Width="800" Height="480" Background="White"
                CornerRadius="16" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.08" Direction="270"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE: Branding -->
                <Border Grid.Column="0" CornerRadius="16,0,0,16" Background="{StaticResource LoginSidebarBrush}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="30">
                        <!-- Hexagon monogram -->
                        <Grid Width="70" Height="70" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Polygon Points="35,2 62,18 62,52 35,68 8,52 8,18" Fill="Transparent" Stroke="#C9A84C" StrokeThickness="1.5"/>
                            <Polygon Points="35,8 56,21 56,49 35,62 14,49 14,21" Fill="#C9A84C"/>
                            <TextBlock Text="RG" FontFamily="Georgia, Times New Roman, serif" FontSize="24" FontWeight="Bold" Foreground="#0B1C2C" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Hotel name -->
                        <TextBlock Text="RG Hotel Premium" FontFamily="Georgia, Times New Roman, serif" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                        <!-- Gold divider line -->
                        <Rectangle Height="1" Width="100" Fill="#C9A84C" Margin="0,0,0,8" Opacity="0.8"/>

                        <!-- Subtitle -->
                        <TextBlock HorizontalAlignment="Center" FontFamily="Georgia, Times New Roman, serif" FontSize="10" Foreground="#C9A84C" Margin="0,0,0,30">
                            <Run Text="G "/><Run Text="R "/><Run Text="A "/><Run Text="N "/><Run Text="D "/>
                            <Run Text="  "/>
                            <Run Text="H "/><Run Text="O "/><Run Text="S "/><Run Text="P "/><Run Text="I "/><Run Text="T "/><Run Text="A "/><Run Text="L "/><Run Text="I "/><Run Text="T "/><Run Text="Y "/>
                        </TextBlock>

                        <TextBlock Text="Welcome to the staff and administrator portal. Please authenticate tracking your shift." 
                                   Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap" TextAlignment="Center" LineHeight="20"/>
                    </StackPanel>
                </Border>

                <!-- RIGHT SIDE: Form -->
                <Grid Grid.Column="1" Margin="48,40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> 
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,24">
                        <TextBlock Text="Sign In" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="Access the Property Management System" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <!-- Error Message -->
                        <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,20"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Role -->
                        <TextBlock Text="ROLE" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding Roles}" 
                                  SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                                  FontSize="14" Padding="12,10" Background="#FAFBFC" 
                                  BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" Margin="0,0,0,16"/>

                        <!-- Username -->
                        <TextBlock Text="USERNAME" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                                 FontSize="14" Padding="12,10" Background="#FAFBFC" 
                                 BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" Margin="0,0,0,16"/>

                        <!-- Password -->
                        <TextBlock Text="PASSWORD" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                        <PasswordBox x:Name="PasswordBox" PasswordChanged="PasswordBox_PasswordChanged"
                                     FontSize="14" Padding="12,10" Background="#FAFBFC" 
                                     BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" Margin="0,0,0,8"/>
                        
                        <TextBlock Text="Forgot your password? Contact IT." FontSize="11" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right" Cursor="Hand" TextDecorations="Underline"/>
                    </StackPanel>

                    <!-- Authenticate button with inline progress indicator -->
                    <Button Grid.Row="2" Command="{Binding LoginCommand}"
                            Background="{StaticResource AccentBrush}" Foreground="White" 
                            FontSize="14" FontWeight="SemiBold" Padding="0,14" 
                            BorderThickness="0" Cursor="Hand" Margin="0,20,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentDarkBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ProgressBar Width="48" Height="6" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,8,0"/>
                            <TextBlock Text="Authenticate →" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Busy overlay (blocks form while authenticating) -->
                    <Border Grid.RowSpan="3" Background="#80000000" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" Panel.ZIndex="40">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Width="220" Height="8" Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Text="Authenticating..." Foreground="White" FontWeight="SemiBold" Margin="0,12,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>