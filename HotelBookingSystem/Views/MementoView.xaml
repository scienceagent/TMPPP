<UserControl x:Class="HotelBookingSystem.Views.MementoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:converters="clr-namespace:HotelBookingSystem.Converters">

    <UserControl.Resources>
        <converters:NumberToVisibilityConverter x:Key="NumberToVisibilityConverter"/>
        
        <Style x:Key="ICard" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="20"/>
            <Setter Property="BorderBrush"     Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FLbl" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>

        <Style x:Key="Field" TargetType="TextBox">
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="10,9"/>
            <Setter Property="BorderBrush"     Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"      Value="#FAFBFC"/>
            <Setter Property="Margin"          Value="0,0,0,14"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#8B5CF6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WizBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Background" Value="#CBD5E1"/>
                                <Setter Property="Foreground"               Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,32">

            <!-- ══════ HEADER ══════ -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Background="#0F172A" CornerRadius="4" Padding="8,3" Margin="0,0,10,0">
                            <TextBlock Text="LAB 6 · MEMENTO" FontSize="10" FontWeight="Bold" Foreground="#C4B5FD"/>
                        </Border>
                        <TextBlock Text="Smart Booking Form"
                                   FontSize="24" FontWeight="SemiBold" Foreground="#0F172A"/>
                    </StackPanel>
                    <TextBlock FontSize="12" Foreground="#64748B" TextWrapping="Wrap">
                        <Run>Every field change auto-saves a snapshot via </Run>
                        <Run FontFamily="Cascadia Code, Consolas" FontSize="11">BookingFormHistory.SaveState()</Run>
                        <Run>. Undo restores the raw state — no inverse operation needed.</Run>
                        <Run FontWeight="SemiBold"> Named checkpoints let staff jump to any saved moment.</Run>
                    </TextBlock>
                </StackPanel>

                <!-- Undo/Redo counter + status -->
                <Border Grid.Column="1" Style="{StaticResource ICard}" Padding="16,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="↩  Undo" Command="{Binding MementoCtrl.UndoCommand}"
                                    Background="#D97706" Style="{StaticResource WizBtn}"
                                    Padding="12,8" Margin="0,0,8,0"/>
                            <Button Content="↪  Redo" Command="{Binding MementoCtrl.RedoCommand}"
                                    Background="#2563EB" Style="{StaticResource WizBtn}"
                                    Padding="12,8" Margin="0,0,8,0"/>
                            <Button Content="💾  Save" Command="{Binding MementoCtrl.QuickSaveCommand}"
                                    Background="#64748B" Style="{StaticResource WizBtn}"
                                    Padding="12,8"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#FEF3C7" CornerRadius="6" Padding="10,5" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Undo: " FontSize="10" Foreground="#92400E"/>
                                    <TextBlock Text="{Binding MementoCtrl.UndoCount}"
                                               FontSize="13" FontWeight="Bold" Foreground="#D97706"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#EFF6FF" CornerRadius="6" Padding="10,5">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Redo: " FontSize="10" Foreground="#1E3A8A"/>
                                    <TextBlock Text="{Binding MementoCtrl.RedoCount}"
                                               FontSize="13" FontWeight="Bold" Foreground="#2563EB"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════ STATUS BAR ══════ -->
            <Border Background="#F5F3FF" CornerRadius="8" Padding="16,10"
                    BorderBrush="#DDD6FE" BorderThickness="1" Margin="0,0,0,16">
                <TextBlock Text="{Binding MementoCtrl.StatusMessage}"
                           FontSize="12" Foreground="#4C1D95" TextWrapping="Wrap"/>
            </Border>

            <!-- ══════ WIZARD STEP TABS ══════ -->
            <Border Style="{StaticResource ICard}" Padding="0" Margin="0,0,0,16">
                <StackPanel>
                    <!-- Step indicators -->
                    <Grid Margin="20,16,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Step 1 -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,10,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#E2E8F0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MementoCtrl.IsStep0}" Value="True">
                                                <Setter Property="Background" Value="#8B5CF6"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MementoCtrl.IsGuestValid}" Value="True">
                                                <Setter Property="Background" Value="#15803D"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="1" Foreground="White" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Guest" FontSize="12" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBlock Text="Name, email, passport" FontSize="10" Foreground="#94A3B8"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Step 2 -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,10,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#E2E8F0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MementoCtrl.IsStep1}" Value="True">
                                                <Setter Property="Background" Value="#8B5CF6"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MementoCtrl.IsRoomValid}" Value="True">
                                                <Setter Property="Background" Value="#15803D"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="2" Foreground="White" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Room" FontSize="12" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBlock Text="Room number, type, price" FontSize="10" Foreground="#94A3B8"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Step 3 -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,10,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#E2E8F0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MementoCtrl.IsStep2}" Value="True">
                                                <Setter Property="Background" Value="#8B5CF6"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MementoCtrl.IsDatesValid}" Value="True">
                                                <Setter Property="Background" Value="#15803D"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="3" Foreground="White" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Details" FontSize="12" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <TextBlock Text="Dates, type, requests" FontSize="10" Foreground="#94A3B8"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Separator Margin="20,14,20,0" Background="#E2E8F0"/>

                    <!-- ── STEP 0: Guest ── -->
                    <StackPanel Margin="20,16,20,20"
                                Visibility="{Binding MementoCtrl.IsStep0,
                                             Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="FULL NAME *" Style="{StaticResource FLbl}"/>
                                <TextBox Text="{Binding MementoCtrl.GuestName,
                                                        UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Field}"/>
                                <TextBlock Text="EMAIL *" Style="{StaticResource FLbl}"/>
                                <TextBox Text="{Binding MementoCtrl.GuestEmail,
                                                        UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Field}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="NATIONALITY" Style="{StaticResource FLbl}"/>
                                <TextBox Text="{Binding MementoCtrl.GuestNationality,
                                                        UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Field}"/>
                                <TextBlock Text="PASSPORT / ID" Style="{StaticResource FLbl}"/>
                                <TextBox Text="{Binding MementoCtrl.GuestPassport,
                                                        UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Field}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- ── STEP 1: Room ── -->
                    <StackPanel Margin="20,16,20,20"
                                Visibility="{Binding MementoCtrl.IsStep1,
                                             Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="ROOM NUMBER *" Style="{StaticResource FLbl}"/>
                                <TextBox Text="{Binding MementoCtrl.RoomNumber,
                                                        UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Field}"/>
                                <TextBlock Text="ROOM TYPE" Style="{StaticResource FLbl}"/>
                                <ComboBox ItemsSource="{Binding MementoCtrl.RoomTypes}"
                                          SelectedItem="{Binding MementoCtrl.RoomType, Mode=TwoWay}"
                                          Padding="10,9" Margin="0,0,0,14" Background="#FAFBFC"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="BASE PRICE / NIGHT (USD) *" Style="{StaticResource FLbl}"/>
                                <TextBox Text="{Binding MementoCtrl.RoomPrice,
                                                        Converter={StaticResource DecimalInputConverter},
                                                        UpdateSourceTrigger=LostFocus}"
                                         Style="{StaticResource Field}"/>
                                <TextBlock Text="CAPACITY (GUESTS)" Style="{StaticResource FLbl}"/>
                                <TextBox Text="{Binding MementoCtrl.RoomCapacity,
                                                        UpdateSourceTrigger=LostFocus}"
                                         Style="{StaticResource Field}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- ── STEP 2: Details ── -->
                    <StackPanel Margin="20,16,20,20"
                                Visibility="{Binding MementoCtrl.IsStep2,
                                             Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CHECK-IN *" Style="{StaticResource FLbl}"/>
                                <DatePicker SelectedDate="{Binding MementoCtrl.CheckIn, Mode=TwoWay}"
                                            DisplayDateStart="{x:Static sys:DateTime.Today}"
                                            Padding="10,8" Margin="0,0,0,14" BorderBrush="#E2E8F0"/>
                                <TextBlock Text="BOOKING TYPE" Style="{StaticResource FLbl}"/>
                                <ComboBox ItemsSource="{Binding MementoCtrl.BookingTypes}"
                                          SelectedItem="{Binding MementoCtrl.BookingType, Mode=TwoWay}"
                                          Padding="10,9" Background="#FAFBFC"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="CHECK-OUT *" Style="{StaticResource FLbl}"/>
                                <DatePicker SelectedDate="{Binding MementoCtrl.CheckOut, Mode=TwoWay}"
                                            DisplayDateStart="{Binding MementoCtrl.CheckIn}"
                                            Padding="10,8" Margin="0,0,0,14" BorderBrush="#E2E8F0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="Duration:" FontSize="12" Foreground="#64748B"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Border Background="#8B5CF6" CornerRadius="16" Padding="12,4">
                                        <TextBlock FontSize="14" FontWeight="Bold" Foreground="White">
                                            <Run Text="{Binding MementoCtrl.Nights, Mode=OneWay}"/>
                                            <Run Text=" nights"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <CheckBox IsChecked="{Binding MementoCtrl.BreakfastIncluded, Mode=TwoWay}"
                                  Content="Breakfast included" FontSize="12" Margin="0,0,0,8"/>
                        <CheckBox IsChecked="{Binding MementoCtrl.AirportTransfer, Mode=TwoWay}"
                                  Content="Airport transfer" FontSize="12" Margin="0,0,0,14"/>
                        <TextBlock Text="SPECIAL REQUEST" Style="{StaticResource FLbl}"/>
                        <TextBox Text="{Binding MementoCtrl.SpecialRequest, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Field}" Height="56" TextWrapping="Wrap"
                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>

                    <!-- Step navigation -->
                    <Border Background="#F8FAFC" CornerRadius="0,0,10,10" Padding="20,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Content="← Back"
                                    Command="{Binding MementoCtrl.PrevStepCommand}"
                                    Background="#475569" Style="{StaticResource WizBtn}"
                                    Padding="16,9"/>

                            <!-- Summary pill -->
                            <Border Grid.Column="1" Background="#EDE9FE" CornerRadius="6"
                                    Padding="12,6" Margin="12,0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding MementoCtrl.GuestName}"
                                               FontSize="11" Foreground="#4C1D95" VerticalAlignment="Center"
                                               Visibility="{Binding MementoCtrl.IsGuestValid,
                                                            Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <TextBlock Text=" · " FontSize="11" Foreground="#7C3AED"
                                               Visibility="{Binding MementoCtrl.IsRoomValid,
                                                            Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <TextBlock Text="{Binding MementoCtrl.RoomNumber}"
                                               FontSize="11" Foreground="#4C1D95" VerticalAlignment="Center"
                                               Visibility="{Binding MementoCtrl.IsRoomValid,
                                                            Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <TextBlock Text=" · " FontSize="11" Foreground="#7C3AED"
                                               Visibility="{Binding MementoCtrl.IsDatesValid,
                                                            Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <TextBlock FontSize="11" Foreground="#4C1D95"
                                               Visibility="{Binding MementoCtrl.IsDatesValid,
                                                            Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Run Text="{Binding MementoCtrl.Nights, Mode=OneWay}"/>
                                        <Run Text=" nights"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Button Grid.Column="2" Content="Next →"
                                    Command="{Binding MementoCtrl.NextStepCommand}"
                                    Background="#8B5CF6" Style="{StaticResource WizBtn}"
                                    Padding="16,9"/>

                            <Button Grid.Column="4" Content="✓  Create Booking"
                                    Command="{Binding MementoCtrl.SubmitCommand}"
                                    Background="#15803D" Style="{StaticResource WizBtn}"
                                    Padding="20,9"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ══════ BOTTOM ROW: Checkpoints + Timeline ══════ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Named Checkpoints -->
                <Border Grid.Column="0" Style="{StaticResource ICard}" Padding="0">
                    <StackPanel>
                        <Border Background="#7C3AED" CornerRadius="10,10,0,0" Padding="16,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📌" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="NAMED CHECKPOINTS" FontSize="11" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text=" — Caretaker stores opaque Mementos"
                                           FontSize="10" Foreground="#C4B5FD"
                                           VerticalAlignment="Center"
                                           FontFamily="Cascadia Code, Consolas"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Margin="16,14,16,0">
                            <TextBlock FontSize="10" Foreground="#94A3B8" TextWrapping="Wrap"
                                       Margin="0,0,0,12"
                                       Text="Name a checkpoint to jump back to any moment. The Caretaker treats each Memento as an opaque token — it cannot read or modify the form data inside."/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding MementoCtrl.CheckpointName,
                                                         UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,8" BorderBrush="#E2E8F0"
                                         Background="#FAFBFC" FontSize="12"/>
                                <Button Grid.Column="2" Content="📌  Save"
                                        Command="{Binding MementoCtrl.SaveCheckpointCommand}"
                                        Background="#7C3AED" Style="{StaticResource WizBtn}"
                                        Padding="14,9"/>
                            </Grid>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding MementoCtrl.NamedCheckpoints}"
                                      Margin="14,0,14,14">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" Padding="12,10" CornerRadius="8"
                                            Background="#F5F3FF" BorderBrush="#DDD6FE" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Name}" FontSize="12"
                                                           FontWeight="SemiBold" Foreground="#4C1D95"
                                                           Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding Summary}" FontSize="10"
                                                           Foreground="#6D28D9" TextWrapping="Wrap"/>
                                                <TextBlock FontSize="9" Foreground="#94A3B8" Margin="0,2,0,0">
                                                    <Run Text="{Binding TimeFmt, Mode=OneWay}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding AgeFmt, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="↩ Restore"
                                                    Command="{Binding DataContext.MementoCtrl.JumpCheckpointCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Name}"
                                                    Background="#7C3AED" Style="{StaticResource WizBtn}"
                                                    Padding="10,6" FontSize="10"
                                                    VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="16,0,16,14" FontSize="11" Foreground="#94A3B8"
                                   Text="No named checkpoints yet. Name and save one above."
                                   Visibility="{Binding MementoCtrl.NamedCount,
                                                Converter={StaticResource NumberToVisibilityConverter}}"/>
                    </StackPanel>
                </Border>

                <!-- Auto Checkpoint Timeline -->
                <Border Grid.Column="2" Style="{StaticResource ICard}" Padding="0">
                    <StackPanel>
                        <Border Background="#4F46E5" CornerRadius="10,10,0,0" Padding="16,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏱" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="AUTO CHECKPOINT TIMELINE" FontSize="11"
                                           FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Margin="16,14,16,10" FontSize="10" Foreground="#94A3B8" TextWrapping="Wrap"
                                   Text="Every field change auto-creates a snapshot. Undo walks back through this timeline. Newest first."/>

                        <ItemsControl ItemsSource="{Binding MementoCtrl.CheckpointTimeline}"
                                      MaxHeight="340" Margin="14,0,14,14">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,5" Padding="10,8" CornerRadius="6"
                                            Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#0F172A" CornerRadius="4"
                                                    Padding="6,2" Margin="0,0,10,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TimestampFmt}"
                                                           FontFamily="Cascadia Code, Consolas"
                                                           FontSize="9" Foreground="#7DD3FC"/>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Label}" FontSize="11"
                                                           FontWeight="SemiBold" Foreground="#0F172A"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Summary}" FontSize="9"
                                                           Foreground="#64748B"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════ PATTERN + SOLID NOTE ══════ -->
            <Border Style="{StaticResource ICard}" Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PATTERN STRUCTURE" FontSize="10" FontWeight="Bold"
                                   Foreground="#64748B" Margin="0,0,0,10"/>
                        <Border Background="#F8FAFC" CornerRadius="8" Padding="14,12"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <TextBlock FontFamily="Cascadia Code, Consolas"
                                       FontSize="10" Foreground="#0F172A" LineHeight="18">
                                <Run>BookingFormOriginator</Run><LineBreak/>
                                <Run>  Save(label?) → BookingFormSnapshot</Run><LineBreak/>
                                <Run>  Restore(snapshot) → restores all fields</Run><LineBreak/>
                                <LineBreak/>
                                <Run>BookingFormSnapshot  (Memento)</Run><LineBreak/>
                                <Run>  internal constructor</Run><LineBreak/>
                                <Run>  internal field accessors</Run><LineBreak/>
                                <Run>  public: Label, Summary, SavedAt</Run><LineBreak/>
                                <LineBreak/>
                                <Run>BookingFormHistory  (Caretaker)</Run><LineBreak/>
                                <Run>  SaveState(originator)</Run><LineBreak/>
                                <Run>  Undo(originator)</Run><LineBreak/>
                                <Run>  Redo(originator)</Run><LineBreak/>
                                <Run>  SaveNamedCheckpoint(name)</Run><LineBreak/>
                                <Run>  JumpToCheckpoint(name)</Run>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="COMMAND vs MEMENTO" FontSize="10" FontWeight="Bold"
                                   Foreground="#64748B" Margin="0,0,0,10"/>
                        <Border Background="#FEF3C7" CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Command Undo" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#92400E"/>
                                <TextBlock FontSize="10" Foreground="#374151" TextWrapping="Wrap"
                                           Text="Executes the inverse operation. ConfirmBooking → Undo resets status to Pending. Knows HOW to reverse."/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F5F3FF" CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Memento Undo" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#4C1D95"/>
                                <TextBlock FontSize="10" Foreground="#374151" TextWrapping="Wrap"
                                           Text="Restores raw saved state. No inverse computation. Perfect for multi-field forms where calculating 'undo 8 simultaneous changes' is impractical."/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F0FDF4" CornerRadius="6" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="S ✓  Encapsulation" FontSize="11"
                                           FontWeight="SemiBold" Foreground="#15803D"/>
                                <TextBlock FontSize="10" Foreground="#374151" TextWrapping="Wrap"
                                           Text="Caretaker (BookingFormHistory) stores snapshots but never reads GuestName, RoomPrice, or any field inside them. Only Originator.Restore() accesses internal state."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
