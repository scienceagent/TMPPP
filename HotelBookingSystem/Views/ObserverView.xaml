<UserControl x:Class="HotelBookingSystem.Views.ObserverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:HotelBookingSystem.Converters">

    <UserControl.Resources>
        <Style x:Key="ICard" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="20"/>
            <Setter Property="BorderBrush"     Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FLbl" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>
        
        <converters:NumberToVisibilityConverter   x:Key="NumberToVisibilityConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,32">

            <!-- ══════ HEADER ══════ -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Background="#0F172A" CornerRadius="4" Padding="8,3" Margin="0,0,10,0">
                            <TextBlock Text="LAB 6 · OBSERVER" FontSize="10" FontWeight="Bold" Foreground="#F59E0B"/>
                        </Border>
                        <TextBlock Text="Live Hotel Dashboard"
                                   FontSize="24" FontWeight="SemiBold" Foreground="#0F172A"/>
                    </StackPanel>
                    <TextBlock FontSize="12" Foreground="#64748B" TextWrapping="Wrap">
                        <Run>Five independent observers react to every booking event simultaneously.</Run>
                        <Run>Subject (</Run><Run FontFamily="Cascadia Code, Consolas" FontSize="11">BookingEventMonitor</Run>
                        <Run>) notifies all registered </Run>
                        <Run FontFamily="Cascadia Code, Consolas" FontSize="11">IBookingObserver</Run>
                        <Run> instances — it never knows what they do.</Run>
                        <Run FontWeight="SemiBold"> Create or confirm a booking to watch the dashboard update live.</Run>
                    </TextBlock>
                </StackPanel>

                <!-- Refresh + Last activity -->
                <Border Grid.Column="1" Style="{StaticResource ICard}"
                        Padding="16,12" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="LAST ACTIVITY" FontSize="9" FontWeight="Bold"
                                   Foreground="#64748B" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Background="#0F172A" CornerRadius="4" Padding="7,3" Margin="0,0,8,0">
                                <TextBlock Text="{Binding ObserverCtrl.LastActivityTime}"
                                           FontFamily="Cascadia Code, Consolas" FontSize="11"
                                           Foreground="#7DD3FC"/>
                            </Border>
                            <TextBlock Text="{Binding ObserverCtrl.LastActivity}"
                                       FontSize="12" Foreground="#374151"
                                       VerticalAlignment="Center" MaxWidth="240"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Button Content="↻  Refresh Dashboard"
                                Command="{Binding ObserverCtrl.RefreshCommand}"
                                Background="#2563EB" Foreground="White"
                                FontSize="11" FontWeight="SemiBold"
                                Padding="14,7" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="{TemplateBinding Background}"
                                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#1D4ED8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════ KPI CARDS (4-column) ══════ -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Bookings -->
                <Border Grid.Column="0" CornerRadius="10" Padding="20,18">
                    <Border.Background>
                        <SolidColorBrush Color="#EFF6FF"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#BFDBFE"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>
                        <Thickness>1</Thickness>
                    </Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📋" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="TOTAL BOOKINGS" FontSize="10" FontWeight="Bold"
                                       Foreground="#2563EB" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ObserverCtrl.KpiBookings.Value}"
                                   FontSize="36" FontWeight="Bold" Foreground="#1E3A8A"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ObserverCtrl.KpiBookings.Delta}"
                                   FontSize="10" Foreground="#3B82F6" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Revenue -->
                <Border Grid.Column="2" CornerRadius="10" Padding="20,18">
                    <Border.Background>
                        <SolidColorBrush Color="#F0FDF4"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#BBF7D0"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>
                        <Thickness>1</Thickness>
                    </Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="💰" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="PIPELINE REVENUE" FontSize="10" FontWeight="Bold"
                                       Foreground="#15803D" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ObserverCtrl.KpiRevenue.Value}"
                                   FontSize="36" FontWeight="Bold" Foreground="#14532D"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ObserverCtrl.KpiRevenue.Delta}"
                                   FontSize="10" Foreground="#16A34A" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Occupancy -->
                <Border Grid.Column="4" CornerRadius="10" Padding="20,18">
                    <Border.Background>
                        <SolidColorBrush Color="#ECFEFF"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#A5F3FC"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>
                        <Thickness>1</Thickness>
                    </Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="🏨" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="OCCUPANCY RATE" FontSize="10" FontWeight="Bold"
                                       Foreground="#0891B2" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ObserverCtrl.KpiOccupancy.Value}"
                                   FontSize="36" FontWeight="Bold" Foreground="#0E7490"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ObserverCtrl.KpiOccupancy.Delta}"
                                   FontSize="10" Foreground="#06B6D4" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Alerts -->
                <Border Grid.Column="6" CornerRadius="10" Padding="20,18">
                    <Border.Background>
                        <SolidColorBrush Color="#FEF2F2"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#FECACA"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>
                        <Thickness>1</Thickness>
                    </Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="🔔" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="ACTIVE ALERTS" FontSize="10" FontWeight="Bold"
                                       Foreground="#DC2626" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ObserverCtrl.KpiAlerts.Value}"
                                   FontSize="36" FontWeight="Bold" Foreground="#991B1B"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ObserverCtrl.KpiAlerts.Delta}"
                                   FontSize="10" Foreground="#EF4444" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════ MIDDLE ROW: Occupancy + Revenue + Observer list ══════ -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <!-- Occupancy terminal -->
                <Border Grid.Column="0" Style="{StaticResource ICard}" Padding="0">
                    <StackPanel>
                        <Border Background="#0891B2" CornerRadius="10,10,0,0" Padding="16,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏨" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="OCCUPANCY MONITOR" FontSize="11" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text=" · OccupancyObserver" FontSize="10"
                                           Foreground="#A5F3FC" VerticalAlignment="Center"
                                           FontFamily="Cascadia Code, Consolas"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#0F172A" CornerRadius="0,0,10,10" Padding="18" MinHeight="140">
                            <TextBlock Text="{Binding ObserverCtrl.OccupancyBreakdown}"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="12" Foreground="#67E8F9"
                                       TextWrapping="Wrap" LineHeight="20"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Revenue terminal -->
                <Border Grid.Column="2" Style="{StaticResource ICard}" Padding="0">
                    <StackPanel>
                        <Border Background="#15803D" CornerRadius="10,10,0,0" Padding="16,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💰" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="REVENUE TRACKER" FontSize="11" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text=" · RevenueObserver" FontSize="10"
                                           Foreground="#86EFAC" VerticalAlignment="Center"
                                           FontFamily="Cascadia Code, Consolas"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#0F172A" CornerRadius="0,0,10,10" Padding="18" MinHeight="140">
                            <TextBlock Text="{Binding ObserverCtrl.RevenueBreakdown}"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="12" Foreground="#86EFAC"
                                       TextWrapping="Wrap" LineHeight="20"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Observer registry -->
                <Border Grid.Column="4" Style="{StaticResource ICard}" Padding="0">
                    <StackPanel>
                        <Border Background="#4F46E5" CornerRadius="10,10,0,0" Padding="14,12">
                            <TextBlock Text="REGISTERED OBSERVERS" FontSize="11"
                                       FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <StackPanel Margin="14,12">
                            <TextBlock FontSize="10" Foreground="#94A3B8" Margin="0,0,0,10" TextWrapping="Wrap"
                                       Text="All subscribed to BookingEventMonitor. Subject notifies each in order."/>
                            <ItemsControl ItemsSource="{Binding ObserverCtrl.ObserverRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" Padding="10,8"
                                                CornerRadius="6" Background="#F8FAFC"
                                                BorderBrush="#E2E8F0" BorderThickness="1">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                                             VerticalAlignment="Center">
                                                        <Ellipse.Fill>
                                                            <SolidColorBrush Color="#22C55E"/>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="#0F172A"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="9" Foreground="#94A3B8"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════ BOTTOM ROW: Audit Log + Alerts ══════ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Audit Log -->
                <Border Grid.Column="0" Style="{StaticResource ICard}" Padding="0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#7C3AED"
                                CornerRadius="10,10,0,0" Padding="16,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📜" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="BOOKING AUDIT LOG" FontSize="11" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text=" · AuditLogObserver" FontSize="10"
                                           Foreground="#C4B5FD" VerticalAlignment="Center"
                                           FontFamily="Cascadia Code, Consolas"/>
                            </StackPanel>
                        </Border>

                        <DataGrid DockPanel.Dock="Bottom"
                                  ItemsSource="{Binding ObserverCtrl.AuditEntries}"
                                  IsReadOnly="True" AutoGenerateColumns="False"
                                  BorderThickness="0" Background="White"
                                  RowBackground="White" AlternatingRowBackground="#FAFBFC"
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                                  HeadersVisibility="Column" SelectionMode="Single"
                                  MaxHeight="260" ScrollViewer.VerticalScrollBarVisibility="Auto">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"      Value="#F8FAFC"/>
                                    <Setter Property="Foreground"      Value="#64748B"/>
                                    <Setter Property="FontSize"        Value="10"/>
                                    <Setter Property="FontWeight"      Value="Bold"/>
                                    <Setter Property="Padding"         Value="12,8"/>
                                    <Setter Property="BorderBrush"     Value="#E2E8F0"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Time" Width="66"
                                                    Binding="{Binding TimestampFmt}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Cascadia Code, Consolas"/>
                                            <Setter Property="FontSize"   Value="10"/>
                                            <Setter Property="Foreground" Value="#64748B"/>
                                            <Setter Property="Margin"     Value="12,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Event type badge -->
                                <DataGridTemplateColumn Header="Event" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding BadgeColor}"
                                                    CornerRadius="4" Padding="6,2"
                                                    Margin="8,4" VerticalAlignment="Center"
                                                    HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding BadgeIcon}"
                                                               FontSize="9" Foreground="White"
                                                               Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding EventType}"
                                                               FontSize="8" FontWeight="Bold"
                                                               Foreground="White"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Guest"    Width="100"
                                                    Binding="{Binding GuestName}"/>
                                <DataGridTextColumn Header="Room"     Width="56"
                                                    Binding="{Binding RoomNumber}"/>
                                <DataGridTextColumn Header="Type"     Width="70"
                                                    Binding="{Binding BookingType}"/>
                                <DataGridTextColumn Header="Value"    Width="80"
                                                    Binding="{Binding TotalFmt}"/>
                                <DataGridTextColumn Header="Details"  Width="*"
                                                    Binding="{Binding Details}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize"   Value="10"/>
                                            <Setter Property="Foreground" Value="#64748B"/>
                                            <Setter Property="Margin"     Value="12,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Alert Panel -->
                <Border Grid.Column="2" Style="{StaticResource ICard}" Padding="0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#DC2626"
                                CornerRadius="10,10,0,0" Padding="16,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔔" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="ALERT MONITOR" FontSize="11" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text=" · AlertObserver" FontSize="10"
                                           Foreground="#FCA5A5" VerticalAlignment="Center"
                                           FontFamily="Cascadia Code, Consolas"/>
                            </StackPanel>
                        </Border>

                        <!-- No alerts placeholder -->
                        <Border DockPanel.Dock="Bottom" Margin="16" CornerRadius="8"
                                Background="#FEF2F2" Padding="16,12"
                                Visibility="{Binding ObserverCtrl.AlertEntries.Count,
                                             Converter={StaticResource NumberToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="✓" FontSize="28" Foreground="#15803D"
                                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="No alerts detected" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#15803D"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="System operating normally" FontSize="10"
                                           Foreground="#64748B" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <ItemsControl DockPanel.Dock="Bottom"
                                      ItemsSource="{Binding ObserverCtrl.AlertEntries}"
                                      Margin="14,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="12,10"
                                            CornerRadius="8" BorderThickness="1"
                                            BorderBrush="{Binding ColorHex}">
                                        <Border.Background>
                                            <SolidColorBrush Color="#FFF1F1"/>
                                        </Border.Background>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Icon}"
                                                           FontSize="12" Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                <Border Background="{Binding ColorHex}"
                                                        CornerRadius="3" Padding="5,1">
                                                    <TextBlock Text="{Binding Severity}"
                                                               FontSize="8" FontWeight="Bold"
                                                               Foreground="White"/>
                                                </Border>
                                                <TextBlock Text="{Binding OccurredAt,
                                                                  StringFormat=HH:mm:ss}"
                                                           FontSize="10" Foreground="#94A3B8"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Cascadia Code, Consolas"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Message}"
                                                       FontSize="11" Foreground="#374151"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- ══════ PATTERN NOTE ══════ -->
            <Border Background="White" CornerRadius="10" Padding="20"
                    BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PATTERN STRUCTURE" FontSize="10" FontWeight="Bold"
                                   Foreground="#64748B" Margin="0,0,0,12"/>
                        <Border Background="#F8FAFC" CornerRadius="8" Padding="16,12"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <TextBlock FontFamily="Cascadia Code, Consolas"
                                       FontSize="11" Foreground="#0F172A" LineHeight="20">
                                <Run>BookingEventMonitor  (Subject)</Run><LineBreak/>
                                <Run>  Subscribe(observer)</Run><LineBreak/>
                                <Run>  Unsubscribe(observer)</Run><LineBreak/>
                                <Run>  Notify(type, booking)  ← fires all</Run><LineBreak/>
                                <LineBreak/>
                                <Run>IBookingObserver  (Observer interface)</Run><LineBreak/>
                                <Run>  OnBookingEvent(evt)</Run><LineBreak/>
                                <LineBreak/>
                                <Run>Concrete observers:</Run><LineBreak/>
                                <Run>  OccupancyObserver</Run><LineBreak/>
                                <Run>  RevenueObserver</Run><LineBreak/>
                                <Run>  AlertObserver</Run><LineBreak/>
                                <Run>  AuditLogObserver</Run><LineBreak/>
                                <Run>  DashboardObserver</Run>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="SOLID ANALYSIS" FontSize="10" FontWeight="Bold"
                                   Foreground="#64748B" Margin="0,0,0,12"/>
                        <StackPanel>
                            <Border Background="#F0FDF4" CornerRadius="6" Padding="12,8">
                                <StackPanel>
                                    <TextBlock Text="S — Single Responsibility ✓" FontSize="11"
                                               FontWeight="SemiBold" Foreground="#15803D"/>
                                    <TextBlock FontSize="10" Foreground="#374151" TextWrapping="Wrap"
                                               Text="Subject manages observer list + notification only. Each observer has ONE job (occupancy, revenue, audit, alerts, dashboard)."/>
                                </StackPanel>
                            </Border>
                            <Border Background="#F0FDF4" CornerRadius="6" Padding="12,8" Margin="0,6,0,0">
                                <StackPanel>
                                    <TextBlock Text="O — Open/Closed ✓" FontSize="11"
                                               FontWeight="SemiBold" Foreground="#15803D"/>
                                    <TextBlock FontSize="10" Foreground="#374151" TextWrapping="Wrap"
                                               Text="Add observer 6 (e.g. HousekeepingObserver) with zero changes to BookingEventMonitor or any existing observer."/>
                                </StackPanel>
                            </Border>
                            <Border Background="#F0FDF4" CornerRadius="6" Padding="12,8" Margin="0,6,0,0">
                                <StackPanel>
                                    <TextBlock Text="D — Dependency Inversion ✓" FontSize="11"
                                               FontWeight="SemiBold" Foreground="#15803D"/>
                                    <TextBlock FontSize="10" Foreground="#374151" TextWrapping="Wrap"
                                               Text="Subject holds List&lt;IBookingObserver&gt; — never OccupancyObserver, never RevenueObserver. Pure abstraction."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
