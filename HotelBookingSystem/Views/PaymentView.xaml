<UserControl x:Class="HotelBookingSystem.Views.PaymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,24">

            <StackPanel Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Border Background="#1565C0" CornerRadius="4" Padding="8,3" Margin="0,0,10,0">
                        <TextBlock Text="ADAPTER" FontSize="10" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <TextBlock Text="Payment Gateway" FontSize="24" FontWeight="SemiBold" Foreground="#263238"/>
                </StackPanel>
                <TextBlock FontSize="12" Foreground="#78909C" TextWrapping="Wrap"
                           Text="StripePaymentGateway (Adaptee) has an incompatible interface — ChargeCard(token, double cents, currency). Our code expects IPaymentService — ProcessPayment(guestId, decimal amount). StripePaymentAdapter translates between the two without touching either side."/>
            </StackPanel>

            <Border Background="White" CornerRadius="10" Padding="20"
                    BorderBrush="#E8E8E8" BorderThickness="1" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Interface translation" FontSize="13" FontWeight="SemiBold"
                               Foreground="#263238" Margin="0,0,0,14"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#E3F2FD" CornerRadius="8" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="Client" FontSize="10" FontWeight="Bold"
                                           Foreground="#1565C0" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <TextBlock Text="PaymentController" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#263238" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="IPaymentService" FontSize="10" Foreground="#1976D2"
                                           HorizontalAlignment="Center" FontFamily="Consolas"/>
                                <TextBlock Text="ProcessPayment(&#10;  string guestId,&#10;  decimal amount)" FontSize="10"
                                           Foreground="#546E7A" HorizontalAlignment="Center"
                                           TextAlignment="Center" Margin="0,4,0,0" FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Grid.Column="1" Text="→" FontSize="22" Foreground="#90A4AE"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <Border Grid.Column="2" Background="#E8F5E9" CornerRadius="8" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="Adapter" FontSize="10" FontWeight="Bold"
                                           Foreground="#2E7D32" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <TextBlock Text="StripePaymentAdapter" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#263238" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="implements IPaymentService&#10;holds StripePaymentGateway"
                                           FontSize="10" Foreground="#546E7A"
                                           HorizontalAlignment="Center" TextAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Grid.Column="3" Text="→" FontSize="22" Foreground="#90A4AE"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <Border Grid.Column="4" Background="#FFF3E0" CornerRadius="8" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="Adaptee" FontSize="10" FontWeight="Bold"
                                           Foreground="#E65100" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <TextBlock Text="StripePaymentGateway" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#263238" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="ChargeCard(&#10;  string token,&#10;  double cents,&#10;  string currency)" FontSize="10"
                                           Foreground="#546E7A" HorizontalAlignment="Center"
                                           TextAlignment="Center" Margin="0,4,0,0" FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="10" Padding="20"
                    BorderBrush="#E8E8E8" BorderThickness="1" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Try it — charge the current guest" FontSize="13" FontWeight="SemiBold"
                               Foreground="#263238" Margin="0,0,0,14"/>

                    <TextBlock Text="AMOUNT (USD)" Foreground="#546E7A" FontSize="12"
                               FontWeight="Medium" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PaymentCtrl.PaymentAmount, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14" Padding="10,8" BorderBrush="#CFD8DC" BorderThickness="1"
                             Background="#FAFAFA" Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="Charge Payment" Command="{Binding ProcessPaymentCommand}"
                                Padding="20,10" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1976D2"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#1565C0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bg" Property="Background" Value="#B0BEC5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Refund" Command="{Binding RefundPaymentCommand}"
                                Padding="20,10" BorderThickness="0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#546E7A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#455A64"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bg" Property="Background" Value="#B0BEC5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <Border Background="#F5F5F5" CornerRadius="6" Padding="14,10">
                        <TextBlock Text="{Binding PaymentCtrl.PaymentStatus}"
                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                   FontSize="13" Foreground="#263238"/>
                    </Border>

                    <Border Background="#E8F5E9" CornerRadius="6" Padding="12,10" Margin="0,10,0,0">
                        <TextBlock FontSize="11" Foreground="#2E7D32" TextWrapping="Wrap">
                            <Run FontWeight="Bold">Note:</Run>
                            <Run>Register a guest first (Step 1 on New Booking page) to get a guest ID. The adapter converts it to a Stripe card token internally.</Run>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
