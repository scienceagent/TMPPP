<UserControl x:Class="HotelBookingSystem.Views.StrategyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:converters="clr-namespace:HotelBookingSystem.Converters">

    <UserControl.Resources>

        <!-- ── Strategy selector card ─────────────────────────────────────── -->
        <Style x:Key="StrategyCard" TargetType="RadioButton">
            <Setter Property="GroupName" Value="PricingStrategy"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="outer" CornerRadius="8" Padding="14,11"
                                Background="White"
                                BorderThickness="1.5" BorderBrush="#E2E8F0">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="outer" Property="Background"  Value="#F0F9FF"/>
                                <Setter TargetName="outer" Property="BorderBrush" Value="#2E9CCA"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="outer" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Info card ──────────────────────────────────────────────────── -->
        <Style x:Key="ICard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Field label ────────────────────────────────────────────────── -->
        <Style x:Key="FLbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- ── Primary action button ──────────────────────────────────────── -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,32">

            <!-- ══════ PAGE HEADER ══════ -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Background="#0F172A" CornerRadius="4" Padding="8,3" Margin="0,0,10,0">
                            <TextBlock Text="LAB 6 · STRATEGY" FontSize="10" FontWeight="Bold" Foreground="#2E9CCA"/>
                        </Border>
                        <TextBlock Text="Room Pricing Calculator"
                                   FontSize="24" FontWeight="SemiBold" Foreground="#0F172A"/>
                    </StackPanel>
                    <TextBlock FontSize="12" Foreground="#64748B" TextWrapping="Wrap">
                        <Run>Six interchangeable pricing algorithms — Standard, Weekend Surge, Early Bird, Last Minute, Long Stay, Seasonal.</Run>
                        <Run>Context (</Run><Run FontFamily="Cascadia Code, Consolas" FontSize="11">RoomPricingCalculator</Run><Run>) delegates all calculation to the active strategy.</Run>
                        <Run FontWeight="SemiBold"> Swapping a strategy never touches the Context.</Run>
                    </TextBlock>
                </StackPanel>
                <!-- Live Strategy Badge -->
                <Border Grid.Column="1" CornerRadius="8" Padding="14,10" VerticalAlignment="Center"
                        Background="{Binding StrategyCtrl.CurrentStrategyColor}">
                    <StackPanel>
                        <TextBlock Text="ACTIVE STRATEGY" FontSize="9" FontWeight="Bold"
                                   Foreground="#FFFFFFCC" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding StrategyCtrl.SelectedStrategyName}"
                                   FontSize="13" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════ MAIN TWO-COLUMN ══════ -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── LEFT: Input form ───────────────────────────────────── -->
                <Border Grid.Column="0" Style="{StaticResource ICard}">
                    <StackPanel>
                        <TextBlock Text="BOOKING PARAMETERS"
                                   FontSize="10" FontWeight="Bold" Foreground="#64748B"
                                   Margin="0,0,0,16"/>

                        <!-- Base price -->
                        <TextBlock Text="BASE PRICE / NIGHT (USD)" Style="{StaticResource FLbl}"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#F1F5F9" CornerRadius="6,0,0,6"
                                    Padding="12,10" BorderBrush="#E2E8F0" BorderThickness="1,1,0,1">
                                <TextBlock Text="$" FontSize="18" FontWeight="Bold" Foreground="#64748B"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBox Grid.Column="1"
                                     Text="{Binding StrategyCtrl.BasePrice,
                                                    Converter={StaticResource DecimalInputConverter},
                                                    UpdateSourceTrigger=LostFocus}"
                                     FontSize="18" FontWeight="Bold" Padding="10,10"
                                     BorderBrush="#E2E8F0" BorderThickness="1"
                                     Background="White">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="BorderBrush" Value="#2E9CCA"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>

                        <!-- Dates -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CHECK-IN" Style="{StaticResource FLbl}"/>
                                <DatePicker SelectedDate="{Binding StrategyCtrl.CheckIn, Mode=TwoWay}"
                                            DisplayDateStart="{x:Static sys:DateTime.Today}"
                                            Padding="10,8" BorderBrush="#E2E8F0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="CHECK-OUT" Style="{StaticResource FLbl}"/>
                                <DatePicker SelectedDate="{Binding StrategyCtrl.CheckOut, Mode=TwoWay}"
                                            DisplayDateStart="{Binding StrategyCtrl.CheckIn}"
                                            Padding="10,8" BorderBrush="#E2E8F0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Nights pill -->
                        <Border Background="#F0F9FF" CornerRadius="8" Padding="14,10" Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Duration:" FontSize="12" Foreground="#64748B"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Border Background="#2E9CCA" CornerRadius="20" Padding="14,5">
                                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="White">
                                        <Run Text="{Binding StrategyCtrl.Nights, Mode=OneWay}"/>
                                        <Run Text=" night(s)"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Result card -->
                        <Border CornerRadius="10" Padding="16,14" Margin="0,0,0,10"
                                Background="{Binding StrategyCtrl.CurrentStrategyColor}">
                            <StackPanel>
                                <TextBlock Text="CALCULATED TOTAL"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="#FFFFFF99" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding StrategyCtrl.CurrentResult}"
                                           FontFamily="Cascadia Code, Consolas"
                                           FontSize="11" Foreground="White"
                                           TextWrapping="Wrap" LineHeight="18"/>
                            </StackPanel>
                        </Border>

                        <!-- Best option tip -->
                        <Border Background="#FFF9C4" CornerRadius="8" Padding="12,10"
                                BorderBrush="#F9E44F" BorderThickness="1"
                                Visibility="{Binding StrategyCtrl.BestOptionNote,
                                             Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Text="{Binding StrategyCtrl.BestOptionNote}"
                                       FontSize="11" Foreground="#7C5100" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ─── RIGHT: Strategy selector ───────────────────────────── -->
                <Border Grid.Column="2" Style="{StaticResource ICard}">
                    <StackPanel>
                        <TextBlock Text="SELECT PRICING STRATEGY"
                                   FontSize="10" FontWeight="Bold" Foreground="#64748B"
                                   Margin="0,0,0,6"/>
                        <TextBlock FontSize="11" Foreground="#94A3B8" TextWrapping="Wrap"
                                   Margin="0,0,0,14">
                            Click any strategy to swap it into the Context at runtime.
                            The calculator re-runs instantly — zero code changes in RoomPricingCalculator.
                        </TextBlock>

                        <!-- 1 Standard Rate -->
                        <RadioButton Style="{StaticResource StrategyCard}"
                                     IsChecked="{Binding StrategyCtrl.SelectedStrategyName,
                                                 Converter={StaticResource StringEqualConverter},
                                                 ConverterParameter='Standard Rate', Mode=TwoWay}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#2E9CCA" CornerRadius="4"
                                        Padding="7,3" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Text="1" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Standard Rate" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                                    <TextBlock Text="Base price × nights — no adjustments" FontSize="10" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Grid>
                        </RadioButton>

                        <!-- 2 Weekend Surge -->
                        <RadioButton Style="{StaticResource StrategyCard}"
                                     IsChecked="{Binding StrategyCtrl.SelectedStrategyName,
                                                 Converter={StaticResource StringEqualConverter},
                                                 ConverterParameter='Weekend Surge', Mode=TwoWay}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#F59E0B" CornerRadius="4"
                                        Padding="7,3" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Text="2" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Weekend Surge" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                                    <TextBlock Text="Fri &amp; Sat nights at 1.5× peak rate" FontSize="10" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Grid>
                        </RadioButton>

                        <!-- 3 Early Bird -->
                        <RadioButton Style="{StaticResource StrategyCard}"
                                     IsChecked="{Binding StrategyCtrl.SelectedStrategyName,
                                                 Converter={StaticResource StringEqualConverter},
                                                 ConverterParameter='Early Bird', Mode=TwoWay}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#10B981" CornerRadius="4"
                                        Padding="7,3" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Text="3" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Early Bird" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                                    <TextBlock Text="30+ days: 20% off · 14-29 days: 10% off" FontSize="10" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Grid>
                        </RadioButton>

                        <!-- 4 Last Minute -->
                        <RadioButton Style="{StaticResource StrategyCard}"
                                     IsChecked="{Binding StrategyCtrl.SelectedStrategyName,
                                                 Converter={StaticResource StringEqualConverter},
                                                 ConverterParameter='Last Minute Deal', Mode=TwoWay}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#EF4444" CornerRadius="4"
                                        Padding="7,3" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Text="4" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Last Minute Deal" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                                    <TextBlock Text="0-3 days: 25% off · 4-7 days: 15% off" FontSize="10" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Grid>
                        </RadioButton>

                        <!-- 5 Long Stay -->
                        <RadioButton Style="{StaticResource StrategyCard}"
                                     IsChecked="{Binding StrategyCtrl.SelectedStrategyName,
                                                 Converter={StaticResource StringEqualConverter},
                                                 ConverterParameter='Long Stay Discount', Mode=TwoWay}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#8B5CF6" CornerRadius="4"
                                        Padding="7,3" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Text="5" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Long Stay Discount" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                                    <TextBlock Text="7+ nights: 5% · 14+: 10% · 21+: 15% · 28+: 20% off" FontSize="10" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Grid>
                        </RadioButton>

                        <!-- 6 Seasonal Rate -->
                        <RadioButton Style="{StaticResource StrategyCard}"
                                     IsChecked="{Binding StrategyCtrl.SelectedStrategyName,
                                                 Converter={StaticResource StringEqualConverter},
                                                 ConverterParameter='Seasonal Rate', Mode=TwoWay}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#F97316" CornerRadius="4"
                                        Padding="7,3" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Text="6" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Seasonal Rate" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                                    <TextBlock Text="Summer +40% · Winter +30% · Spring +5% · Autumn std" FontSize="10" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Grid>
                        </RadioButton>

                        <!-- Pattern in action note -->
                        <Border Background="#EFF6FF" CornerRadius="8" Padding="12,10" Margin="0,8,0,0"
                                BorderBrush="#BAE6FD" BorderThickness="1">
                            <TextBlock FontSize="10" Foreground="#0369A1" TextWrapping="Wrap">
                                <Run FontWeight="Bold">Pattern in action: </Run>
                                <Run>Selecting a strategy calls </Run>
                                <Run FontFamily="Cascadia Code, Consolas">calculator.SetStrategy(strategy)</Run>
                                <Run>. The Context delegates immediately. Zero lines changed in </Run>
                                <Run FontFamily="Cascadia Code, Consolas">RoomPricingCalculator</Run>
                                <Run>.</Run>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══════ COMPARISON TABLE ══════ -->
            <Border Style="{StaticResource ICard}" Padding="0" Margin="0,0,0,14">
                <StackPanel>
                    <Border Background="#0F172A" CornerRadius="10,10,0,0" Padding="20,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ALL 6 STRATEGIES — SAME INPUT"
                                       FontSize="11" FontWeight="Bold" Foreground="White"
                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock FontSize="10" Foreground="#64748B" VerticalAlignment="Center">
                                Sorted cheapest first. Green = best deal. Your selection highlighted.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <DataGrid ItemsSource="{Binding StrategyCtrl.ComparisonRows}"
                              IsReadOnly="True" AutoGenerateColumns="False"
                              BorderThickness="0" Background="White"
                              RowBackground="White" AlternatingRowBackground="#FAFBFC"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                              HeadersVisibility="Column" SelectionMode="Single">

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Background" Value="#F0F9FF"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"   Value="#F8FAFC"/>
                                <Setter Property="Foreground"   Value="#64748B"/>
                                <Setter Property="FontSize"     Value="10"/>
                                <Setter Property="FontWeight"   Value="Bold"/>
                                <Setter Property="Padding"      Value="14,10"/>
                                <Setter Property="BorderBrush"  Value="#E2E8F0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>

                            <!-- Strategy name + badges -->
                            <DataGridTemplateColumn Header="Strategy" Width="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="14,5">
                                            <TextBlock Text="{Binding StrategyName}"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <!-- ACTIVE badge -->
                                            <Border Background="#2E9CCA" CornerRadius="4"
                                                    Padding="5,1" Margin="0,0,4,0"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding IsSelected,
                                                                 Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="ACTIVE" FontSize="8"
                                                           FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                            <!-- BEST badge -->
                                            <Border Background="#10B981" CornerRadius="4"
                                                    Padding="5,1" VerticalAlignment="Center"
                                                    Visibility="{Binding IsCheapest,
                                                                 Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="BEST" FontSize="8"
                                                           FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Total"      Width="110"
                                                Binding="{Binding FinalTotalFmt}"/>
                            <DataGridTextColumn Header="Nights"     Width="60"
                                                Binding="{Binding Nights}"/>
                            <DataGridTextColumn Header="Avg / Night" Width="120"
                                                Binding="{Binding EffectiveRateFmt}"/>

                            <!-- vs-Base column with colour coding -->
                            <DataGridTemplateColumn Header="vs. Base" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DiscountFmt}"
                                                   Margin="14,0" VerticalAlignment="Center"
                                                   FontSize="12">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCheapest}" Value="True">
                                                            <Setter Property="Foreground" Value="#15803D"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsMostExpensive}" Value="True">
                                                            <Setter Property="Foreground" Value="#DC2626"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Description" Width="*"
                                                Binding="{Binding Description}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontSize"          Value="10"/>
                                        <Setter Property="Foreground"        Value="#64748B"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin"            Value="14,0"/>
                                        <Setter Property="TextWrapping"      Value="NoWrap"/>
                                        <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- ══════ BREAKDOWN TERMINAL ══════ -->
            <Border Style="{StaticResource ICard}" Padding="0" Margin="0,0,0,14">
                <StackPanel>
                    <!-- Terminal title bar -->
                    <Border Background="#0F172A" CornerRadius="10,10,0,0" Padding="16,11">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#EF4444" Margin="0,0,5,0"/>
                            <Ellipse Width="10" Height="10" Fill="#F59E0B" Margin="0,0,5,0"/>
                            <Ellipse Width="10" Height="10" Fill="#10B981" Margin="0,0,14,0"/>
                            <TextBlock FontSize="11" Foreground="#64748B"
                                       FontFamily="Cascadia Code, Consolas"
                                       VerticalAlignment="Center">
                                <Run Text="RoomPricingCalculator.CalculatePrice()  →  "/>
                                <Run Text="{Binding StrategyCtrl.SelectedStrategyName}"/>
                                <Run Text=".Calculate()"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <!-- Output -->
                    <Border Background="#0F172A" CornerRadius="0,0,10,10" Padding="20" MinHeight="130">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="220">
                            <TextBlock Text="{Binding StrategyCtrl.BreakdownOutput}"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="12" Foreground="#7DD3FC"
                                       TextWrapping="Wrap" LineHeight="20"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ══════ SOLID ANALYSIS ══════ -->
            <Border Style="{StaticResource ICard}">
                <StackPanel>
                    <TextBlock Text="SOLID ANALYSIS — STRATEGY PATTERN"
                               FontSize="10" FontWeight="Bold" Foreground="#64748B"
                               Margin="0,0,0,14"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <Border Background="#F0FDF4" CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Border Background="#15803D" CornerRadius="3" Padding="5,2" Margin="0,0,6,0">
                                            <TextBlock Text="S" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="Single Responsibility ✓" FontSize="12" FontWeight="SemiBold" Foreground="#15803D"/>
                                    </StackPanel>
                                    <TextBlock FontSize="11" Foreground="#374151" TextWrapping="Wrap"
                                               Text="Each ConcreteStrategy owns exactly one algorithm. RoomPricingCalculator owns zero pricing logic."/>
                                </StackPanel>
                            </Border>
                            <Border Background="#F0FDF4" CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Border Background="#15803D" CornerRadius="3" Padding="5,2" Margin="0,0,6,0">
                                            <TextBlock Text="O" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="Open / Closed ✓" FontSize="12" FontWeight="SemiBold" Foreground="#15803D"/>
                                    </StackPanel>
                                    <TextBlock FontSize="11" Foreground="#374151" TextWrapping="Wrap"
                                               Text="Add a 7th strategy (CorporateRate) with zero changes to the Context, UI, or any existing strategy."/>
                                </StackPanel>
                            </Border>
                            <Border Background="#F0FDF4" CornerRadius="6" Padding="12,10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
